{
  "cleanUrls": true,
  "trailingSlash": false,

  "redirects": [
    { "source": "/historia",    "destination": "/o-nas/historia",             "permanent": true },
    { "source": "/o-nas",       "destination": "/o-nas/historia",             "permanent": true },
    { "source": "/kadra",       "destination": "/o-nas/kadra",                "permanent": true },
    { "source": "/lotarynska",  "destination": "/lokalizacje/lotarynska-18",  "permanent": true },
    { "source": "/zakopianska", "destination": "/lokalizacje/zakopianska-8",  "permanent": true },
    { "source": "/wartosci",    "destination": "/o-nas/misja-i-wartosci",     "permanent": true },
    { "source": "/misja",       "destination": "/o-nas/misja-i-wartosci",     "permanent": true },
    { "source": "/zapisy",      "destination": "/rekrutacja",                 "permanent": true },
    { "source": "/blog",         "destination": "/porady", "permanent": true },
    { "source": "/aktualnosci",  "destination": "/porady", "permanent": true },
    { "source": "/style-guide",  "destination": "/",       "permanent": true },
    { "source": "/witaj-swiecie","destination": "/",       "permanent": true },
    { "source": "/hello-world",  "destination": "/",       "permanent": true },

    {
      "source": "/",
      "has": [{ "type": "query", "key": "page_id" }],
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "query", "key": "p" }],
      "destination": "/porady",
      "permanent": true
    },

    { "source": "/category/:slug*",  "destination": "/porady", "permanent": true },
    { "source": "/tag/:slug*",       "destination": "/porady", "permanent": true },
    { "source": "/author/:slug*",    "destination": "/",       "permanent": true },

    { "source": "/feed",             "destination": "/porady", "permanent": true },
    { "source": "/feed/:type*",      "destination": "/porady", "permanent": true },
    { "source": "/comments/feed",    "destination": "/",       "permanent": true },

    { "source": "/about",            "destination": "/o-nas/historia", "permanent": true },
    { "source": "/contact",          "destination": "/kontakt",        "permanent": true },
    { "source": "/services",         "destination": "/",               "permanent": true },
    { "source": "/pricing",          "destination": "/porady/ile-kosztuje-prywatne-przedszkole-goclaw", "permanent": true },
    { "source": "/homes/:slug*",     "destination": "/",               "permanent": true },
    { "source": "/landing/:slug*",   "destination": "/",               "permanent": true }
  ],

  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
