---

<Layout metadata={metadata}>
  <HeroKolorowe />
  <SekcjaOlga />
  <SekcjaKadra />
  <SekcjaLokalna />
  <SekcjaWartosci />
  <SekcjaKuchnia />
  <SekcjaLokalizacje />
  <SekcjaOpinie />
  <SekcjaCTA />
</Layout>
