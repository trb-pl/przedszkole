---
import Layout from '~/layouts/PageLayout.astro';

import HeroKolorowe from '~/components/widgets/HeroKolorowe.astro';
import SekcjaOlga from '~/components/widgets/SekcjaOlga.astro';
import SekcjaKadra from '~/components/widgets/SekcjaKadra.astro';
import SekcjaWartosci from '~/components/widgets/SekcjaWartosci.astro';
import SekcjaLokalizacje from '~/components/widgets/SekcjaLokalizacje.astro';

const metadata = {
  title: 'Kolorowe Przedszkole — Saska Kępa, Warszawa',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroKolorowe />
  <SekcjaOlga />
  <SekcjaKadra />
  <SekcjaWartosci />
  <SekcjaLokalizacje />
</Layout>
