---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import SekcjaZajecia from '~/components/widgets/SekcjaZajecia.astro';

import imgDlaKogo    from '~/assets/images/zakopianska-1.jpg';
import imgFilozofia  from '~/assets/images/zakopianska-filozofia.jpg';
import imgAngielski  from '~/assets/images/zakopianska-angielski.jpg';
import imgPsycholog  from '~/assets/images/zakopianska-psycholog-2.png';

const metadata = {
  title: 'Zakopiańska 8 – Kolorowe Przedszkole | Saska Kępa',
  description: 'Willa z ogrodem 1200m² na Saskiej Kępie. Grupy 4-, 5- i 6-latków, zerówka, sala SI, psycholog na miejscu, native speaker. Otwarte 7:30–17:15.',
  canonical: 'https://koloroweprzedszkole.com/lokalizacje/zakopianska-8',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Zakopiańska 8 – Kolorowe Przedszkole | Saska Kępa',
    description: 'Willa z ogrodem 1200m² na Saskiej Kępie. Grupy 4-, 5- i 6-latków, zerówka, sala SI, psycholog na miejscu, native speaker. Otwarte 7:30–17:15.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/lokalizacje/zakopianska-8',
    site_name: 'Kolorowe Przedszkole',
  },
};

const faqItems = [
  {
    q: 'Dla jakich dzieci jest Zakopiańska?',
    a: 'Na Zakopiańskiej przyjmujemy dzieci w wieku 4 lat (grupa młodsza) oraz 5- i 6-latków, w tym dzieci realizujące roczne przygotowanie przedszkolne — zerówkę. To nasza starsza lokalizacja z bogatszym programem zajęć, salą SI i psychologiem na miejscu każdego dnia.',
  },
  {
    q: 'Do której godziny jest czynne przedszkole na Zakopiańskiej?',
    a: 'Kolorowe Przedszkole na Zakopiańskiej jest otwarte od 7:30 do 17:15. Wierzymy, że każde dziecko powinno mieć swoje popołudnie — z rodziną, we własnym domu i własnym rytmie.',
  },
  {
    q: 'Jak wygląda nauka angielskiego?',
    a: 'Dzieci mają stały kontakt z ciociami mówiącymi wyłącznie po angielsku przez większość dnia — w naturalnych, codziennych sytuacjach. Dodatkowo każda grupa ma codziennie 30-minutowe zajęcia strukturyzowane z języka angielskiego prowadzone przez nauczyciela.',
  },
  {
    q: 'Czy jest psycholog na miejscu?',
    a: 'Tak — Natalia, psycholog, pracuje u nas na co dzień jako stała część zespołu. Zna dzieci z codziennych obserwacji, współpracuje z wychowawczyniami i jest dostępna dla rodziców bez skierowania i bez oczekiwania.',
  },
  {
    q: 'Co to jest sala SI i kto z niej korzysta?',
    a: 'Sala Integracji Sensorycznej (SI) to specjalnie wyposażona przestrzeń wspierająca rozwój zmysłów — równowagę, koordynację i przetwarzanie bodźców. Korzystają z niej wszystkie grupy w ramach regularnego programu tygodniowego, bez dodatkowych opłat.',
  },
  {
    q: 'Czy logopeda jest w czesnym?',
    a: 'Zajęcia z logopedą (Ciocia Lena, 2 razy w tygodniu) są płatne osobno. Natalia, psycholog, pracuje natomiast na co dzień w ramach standardowej opieki — bez dodatkowych opłat.',
  },
  {
    q: 'Jak mogę zapisać dziecko?',
    a: 'Przez formularz na stronie /rekrutacja lub telefonicznie: 605 657 366. Zachęcamy do kontaktu jak najwcześniej — zainteresowanie Zakopiańską jest duże każdego roku i miejsca kończą się przed wakacjami.',
  },
];
---

<Layout metadata={metadata}>

  <!-- JSON-LD schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ChildCare",
    "name": "Kolorowe Przedszkole — Zakopiańska 8",
    "description": "Willa z ogrodem ponad 1200m² na Saskiej Kępie. Dwie kameralne grupy, sala SI, psycholog na miejscu, stały kontakt z native speakerami.",
    "url": "https://koloroweprzedszkole.com/lokalizacje/zakopianska-8",
    "telephone": "+48605657366",
    "email": "przedszkole@kolorowe.eu",
    "openingHours": "Mo-Fr 07:30-17:15",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "ul. Zakopiańska 8",
      "postalCode": "03-977",
      "addressLocality": "Warszawa",
      "addressRegion": "Masovian Voivodeship",
      "addressCountry": "PL"
    },
    "parentOrganization": {
      "@type": "Organization",
      "name": "Kolorowe Przedszkole",
      "url": "https://koloroweprzedszkole.com"
    }
  })} />

  <!-- ─── Hero ──────────────────────────────────────────────── -->
  <section class="relative bg-brand-navy pt-20 pb-12 md:pt-32 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-brand-navy/70 z-10"></div>
    <img
      src="https://placehold.co/1600x700/2D346F/34BBA8?text=Zakopia%C5%84ska+8"
      alt="Kolorowe Przedszkole — Zakopiańska 8, Saska Kępa, Warszawa"
      loading="eager"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative z-20 max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">Lokalizacje</p>
      <h1 class="font-sans italic text-[clamp(2.4rem,6vw,4rem)] text-brand-cream leading-tight mb-6">
        Zakopiańska 8
      </h1>
      <p class="font-sans text-lg text-brand-cream/75 max-w-xl mx-auto leading-relaxed">
        Zaczarowany ogród na Saskiej Kępie.
        Ponad 1200 m² przestrzeni dla dzieci.
      </p>
    </div>
  </section>

  <!-- ─── Intro ─────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans text-xl text-brand-navy/80 leading-relaxed mb-6">
        <strong class="text-brand-navy">Nasze miejsce:</strong> willa w sercu Saskiej Kępy z ogrodem, w którym dzieci
        mają przestrzeń do prawdziwego dzieciństwa.
      </p>
      <p class="font-sans text-lg text-brand-navy/60 leading-relaxed">
        Sala integracji sensorycznej, psycholog na miejscu każdego dnia, zerówka
        i stały kontakt z ciociami mówiącymi wyłącznie po angielsku.
        To świat naszych 4–6 latków!
      </p>
    </div>
  </section>

  <!-- ─── Sekcja 1: Dla kogo? ───────────────────────────────── -->
  <section class="bg-brand-warm">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-[4/3]">
          <Image
            src={imgDlaKogo}
            alt="Dzieci w Kolorowym Przedszkolu na Zakopiańskiej"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-5">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Dla kogo?</p>
          <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
            Willa z ogrodem dla starszych grup
          </h2>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Na Zakopiańskiej działają dwie kameralne grupy — dla 4-latków oraz dla 5- i 6-latków z oddziałem zerówki. Przestronne sale, ogród i bogaty program zajęć — w grupach, gdzie każde dziecko jest znane i zauważone.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Sekcja 2: Godziny i filozofia ───────────────────── -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-[4/3] md:order-2">
          <Image
            src={imgFilozofia}
            alt="Dzieci bawiące się w ogrodzie Kolorowego Przedszkola"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-5 md:order-1">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Godziny i filozofia</p>
          <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
            Każde dziecko powinno mieć swoje popołudnie
          </h2>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Kolorowe Przedszkole na Zakopiańskiej jest otwarte od poniedziałku do piątku, w godzinach 7:30–17:15.
          </p>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Każde dziecko powinno mieć swoje popołudnie. Czas, który należy do niego i do rodziny — nie do planu zajęć. Dlatego Kolorowe Przedszkole na Zakopiańskiej kończy dzień o 17:15.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Sekcja 3: Angielski ──────────────────────────────── -->
  <section class="bg-brand-warm">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-[4/3]">
          <Image
            src={imgAngielski}
            alt="Dzieci podczas zajęć z języka angielskiego w Kolorowym Przedszkolu"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-5">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Język angielski</p>
          <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
            Angielski — język, nie lekcja
          </h2>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            W Kolorowym Przedszkolu na Zakopiańskiej dzieci mają stały kontakt z ciociami mówiącymi wyłącznie po angielsku — przez większość dnia, w naturalnych, codziennych sytuacjach.
          </p>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Niezależnie od tego każda grupa ma codziennie 30-minutowe zajęcia z języka angielskiego prowadzone przez nauczyciela.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Sekcja 4: Sala SI ────────────────────────────────── -->
  <section class="bg-brand-cream">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-[4/3] md:order-2">
          <img
            src="https://placehold.co/800x500/E8F7F4/2D346F?text=Sala+SI"
            alt="Sala Integracji Sensorycznej w Kolorowym Przedszkolu na Zakopiańskiej"
            loading="lazy"
            class="w-full h-full object-cover"
          />
        </div>
        <div class="flex flex-col gap-5 md:order-1">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Sala SI</p>
          <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
            Własna sala Integracji Sensorycznej
          </h2>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Przy Zakopiańskiej 8 mamy własną, w pełni wyposażoną salę do zajęć Integracji Sensorycznej (SI). Korzystają z niej wszystkie grupy w ramach regularnego programu tygodniowego.
          </p>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Sala SI to specjalnie przygotowana przestrzeń wspierająca wszechstronny rozwój zmysłów dziecka — równowagę, koordynację oraz przetwarzanie bodźców dotykowych i proprioceptywnych. Dla wielu dzieci to jedno z ulubionych miejsc w przedszkolu.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Sekcja 5: Psycholog ──────────────────────────────── -->
  <section class="bg-brand-warm">
    <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">
        <div class="rounded-2xl overflow-hidden aspect-[4/3]">
          <Image
            src={imgPsycholog}
            alt="Kolorowe Przedszkole — wsparcie psychologiczne na miejscu"
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
            loading="lazy"
          />
        </div>
        <div class="flex flex-col gap-5">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Psycholog</p>
          <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
            Psycholog — na miejscu, nie od święta
          </h2>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Natalia, psycholog, pracuje u nas na co dzień — nie jako pomoc doraźna, ale jako stała część zespołu. Zna dzieci z codziennych obserwacji, współpracuje z wychowawczyniami i jest dostępna dla rodziców.
          </p>
          <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
            Wizyta nie wymaga skierowania ani oczekiwania.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── Sekcja 6: Zajęcia w programie (grid) ─────────────── -->
  <SekcjaZajecia />
  <section class="bg-brand-cream pb-16">
    <div class="max-w-5xl mx-auto px-6">
      <p class="font-sans text-brand-navy/70 text-base leading-relaxed text-center">
        Zajęcia dodatkowe (robotyka, akrobatyka, basen, szachy, judo, balet) są płatne osobno.
        Logopeda — Ciocia Lena, 2 razy w tygodniu — również dostępna za dodatkową opłatą.
      </p>
    </div>
  </section>

  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section class="bg-brand-navy py-24">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/rekrutacja"
          class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
        >
          Rekrutacja 2026/2027
        </a>
        <a
          href="tel:605657366"
          class="inline-block border-2 border-brand-cream/40 text-brand-cream font-sans font-semibold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:border-brand-teal hover:text-brand-teal"
        >
          Zadzwoń i umów wizytę
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────── -->
  <section class="bg-brand-warm py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">Pytania i odpowiedzi</p>
      <h2 class="font-sans italic text-[clamp(2rem,3.5vw,3rem)] text-brand-navy leading-tight mb-4">
        Najczęściej zadawane pytania
      </h2>
      <p class="font-sans text-lg text-brand-navy/60 mb-12">
        Odpowiedzi na pytania, które słyszymy najczęściej od rodziców.
      </p>

      <div class="divide-y divide-brand-navy/10">
        {faqItems.map((item, i) => (
          <details class="group py-5" open={i === 0}>
            <summary class="flex justify-between items-start cursor-pointer gap-4 list-none">
              <span class="font-sans text-brand-navy font-semibold text-lg leading-snug group-open:text-brand-teal transition-colors duration-200">
                {item.q}
              </span>
              <span class="flex-shrink-0 mt-1 text-brand-teal text-2xl font-light transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="font-sans mt-4 text-brand-navy/75 leading-relaxed text-base">
              {item.a}
            </p>
          </details>
        ))}
      </div>

    </div>
  </section>

</Layout>
