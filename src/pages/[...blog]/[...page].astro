---
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';

import Layout from '~/layouts/PageLayout.astro';
import BlogList from '~/components/blog/List.astro';
import Headline from '~/components/blog/Headline.astro';
import Pagination from '~/components/blog/Pagination.astro';
// import PostTags from "~/components/blog/Tags.astro";

import { blogListRobots, getStaticPathsBlogList } from '~/utils/blog';

export const prerender = true;

export const getStaticPaths = (async ({ paginate }) => {
  return await getStaticPathsBlogList({ paginate });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { page } = Astro.props as Props;
const currentPage = page.currentPage ?? 1;

// const allCategories = await findCategories();
// const allTags = await findTags();

const metadata = {
  title: `Porady dla rodziców${currentPage > 1 ? ` — strona ${currentPage}` : ''} — Kolorowe Przedszkole`,
  description: 'Praktyczne porady dla rodziców przedszkolaków z Saskiej Kępy i Gocławia. Adaptacja, wyprawka, rozwój dziecka — z perspektywy Kolorowego Przedszkola.',
  robots: {
    index: blogListRobots?.index && currentPage === 1,
    follow: blogListRobots?.follow,
  },
  openGraph: {
    type: 'blog',
  },
};
---

<Layout metadata={metadata}>
  <div class="bg-brand-warm pt-24 pb-16">
    <div class="max-w-4xl mx-auto px-6">
      <Headline subtitle="Praktyczne porady dla rodziców przedszkolaków — z perspektywy ponad 30 lat doświadczenia.">
        Porady
      </Headline>
      <!-- Kafelki tematyczne -->
      {currentPage === 1 && (
        <div class="mb-14">
          <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-5">O czym piszemy?</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <a href="/porady/adaptacja-w-przedszkolu-saska-kepa"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Adaptacja i rozwój</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Jak przygotować dziecko na przedszkole, ile trwa adaptacja, jak radzić sobie z płaczem przy rozstaniu.</p>
            </a>
            <a href="/porady/ile-kosztuje-prywatne-przedszkole-goclaw"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Koszty i rekrutacja</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Cennik prywatnych przedszkoli na Pradze Południe, co obejmuje czesne, wpisowe i dotacje z urzędu dzielnicy.</p>
            </a>
            <a href="/porady/przedszkole-z-wlasna-kuchnia-praga-poludnie"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Wyżywienie</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Domowe obiady vs. catering, jak karmić wybredne dziecko, alergie pokarmowe w przedszkolu.</p>
            </a>
            <a href="/porady/od-ilu-lat-przyjmuja-do-przedszkola-saska-kepa"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Gotowość przedszkolna</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Od ilu lat do przedszkola, jak rozpoznać gotowość 2,5-latka, czy maluch musi być odpieluchowany.</p>
            </a>
            <a href="/porady/przedszkole-z-ogrodem-goclaw-saska-kepa"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Ogród i ruch</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Własny plac zabaw, codzienna aktywność na dworze, jak radzimy sobie ze smogiem na Pradze Południe.</p>
            </a>
            <a href="/porady/angielski-w-przedszkolu-praga-poludnie"
               class="bg-white rounded-xl p-5 border border-brand-navy/5 hover:border-brand-teal/30 hover:shadow-sm transition-all block">
              <p class="font-sans font-bold text-brand-navy mb-2">Język angielski</p>
              <p class="font-sans text-sm text-brand-navy/60 leading-relaxed">Naturalna nauka przez zabawę, piosenki i codzienne sytuacje — bez kart pracy i odpytywania.</p>
            </a>
          </div>
        </div>
      )}

      <BlogList posts={page.data} />
      <Pagination prevUrl={page.url.prev} nextUrl={page.url.next} />
    </div>
  </div>
</Layout>
