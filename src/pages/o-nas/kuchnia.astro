---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import SchemaBreadcrumbs from '~/components/seo/SchemaBreadcrumbs.astro';

import imgTatiana from '~/assets/images/kuchnia-tatiana.jpg';
import imgZupa    from '~/assets/images/kuchnia-zupa.jpg';
import imgOgrodek from '~/assets/images/kuchnia-hero.jpg';
import imgKanapki from '~/assets/images/kuchnia-kanapki.jpg';
import headerMazy from '~/assets/images/header-mazy.png';

const metadata = {
  title: 'Kuchnia Kolorowego Przedszkola — domowe obiady na Saskiej Kępie',
  description: 'Gotujemy każdego dnia od podstaw — bez cateringu, bez kompromisów. Własny ogródek, lokalni dostawcy z Mazowsza, domowe obiady i dzieci w kuchni. Saska Kępa od 1991.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/kuchnia',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Kuchnia Kolorowego Przedszkola — domowe obiady na Saskiej Kępie',
    description: 'Gotujemy każdego dnia od podstaw — bez cateringu, bez kompromisów. Własny ogródek, lokalni dostawcy z Mazowsza, domowe obiady i dzieci w kuchni. Saska Kępa od 1991.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/kuchnia',
    site_name: 'Kolorowe Przedszkole',
  },
};

const sekcje = [
  {
    img: imgTatiana,
    alt: 'Ciocia Tatiana w kuchni Kolorowego Przedszkola',
    eyebrow: 'Przez żołądek do serca',
    title: 'Gotuje się tu jak w domu',
    body: 'Ciocia Tatiana to doświadczona kucharka, która od lat jest sercem przedszkolnej kuchni. Dzieci ją uwielbiają — i nie tylko za jedzenie. Kuchnię regularnie dogląda też Ciocia Ola, dla której gotowanie to prywatna pasja wyniesiona z mazureckiego domu rodzinnego.',
    flip: false,
  },
  {
    img: imgZupa,
    alt: 'Zupa gotowana na wywarze w Kolorowym Przedszkolu',
    eyebrow: 'Codziennie na talerzu',
    title: 'Polska kuchnia bez kompromisów',
    body: 'Zupy gotowane na wywarze, mięso i ryby od lokalnych dostawców, warzywa od mazowieckich rolników — od lat tych samych. Nie może zabraknąć makaronu z twarogiem i truskawkami ani pierogów z białym serkiem. Dzieci poznają też kuchnie świata: hummus, sos boloński, chaczapuri i ryż z kurczakiem w azjatyckim stylu.',
    flip: true,
  },
  {
    img: imgOgrodek,
    alt: 'Ogródek warzywny Kolorowego Przedszkola — podlewanie roślin',
    eyebrow: 'Z ogrodu na talerz',
    title: 'Własny ogródek',
    body: 'Przy Zakopiańskiej 8 rośnie marchewka, lubczyk, szczypiorek, zielony groszek, pigwa, sałata i pomidorki koktajlowe — a także własne jabłonie. Dzieci same sadzą, podlewają i zbierają — i wiedzą, że pomidor prosto z krzaka smakuje zupełnie inaczej niż ten ze sklepu. Część plonów trafia prosto do kuchni Cioci Tatiany.',
    flip: false,
  },
  {
    img: imgKanapki,
    alt: 'Dzieci robiące kanapki w Kolorowym Przedszkolu',
    eyebrow: 'Samodzielność przy stole',
    title: 'Dzieci w kuchni',
    body: 'Wszystkie dzieci — nawet te najmłodsze — robią sobie kanapki na śniadanie same, każdy według własnego gustu. Regularnie pieczemy razem zdrowe ciastka, a jesienią zbieramy jabłka z naszych jabłoni i pieczemy szarlotkę. Na Wielkanoc dzieci robią mazurek: prawdziwy, z masą i bakaliami. Przy stole uczymy tyle samo co przy tablicy.',
    flip: true,
  },
];

const faqItems = [
  {
    q: 'Czy Kolorowe Przedszkole korzysta z cateringu?',
    a: 'Nie. Gotujemy na miejscu każdego dnia — od podstaw, ze świeżych składników. Śniadanie, obiad i podwieczorek przygotowuje Ciocia Tatiana, doświadczona kucharka.',
  },
  {
    q: 'Skąd pochodzą produkty używane w kuchni przedszkola?',
    a: 'Warzywa, owoce, jaja i mięso kupujemy od lokalnych rolników z województwa mazowieckiego — od lat u tych samych, sprawdzonych dostawców. Część warzyw pochodzi z własnego ogródka przy Zakopiańskiej 8.',
  },
  {
    q: 'Czy przedszkole uwzględnia alergie pokarmowe?',
    a: 'Staramy się wychodzić naprzeciw potrzebom dzieci z alergiami i nietolerancjami pokarmowymi — zawsze po uprzednich konsultacjach z rodzicami. Należy jednak pamiętać, że w naszej kuchni pracuje jedna kucharka, dlatego nie jesteśmy w stanie obsłużyć bardzo złożonych diet wykluczeniowych. Zapraszamy do rozmowy — razem znajdziemy najlepsze rozwiązanie.',
  },
  {
    q: 'Czy rodzice mogą sprawdzić co dziecko je w przedszkolu?',
    a: 'Tak. Menu planujemy co tydzień z wyprzedzeniem i wywieszamy na tablicy ogłoszeń. Rodzice wiedzą, co dziecko jadło i co będzie jadło — bez niespodzianek.',
  },
  {
    q: 'Czy dzieci gotują w przedszkolu?',
    a: 'Tak. Wszystkie dzieci — nawet te najmłodsze — robią sobie kanapki na śniadanie samodzielnie, ze świeżych składników. Regularnie pieczemy razem zdrowe ciastka. Jesienią zbieramy jabłka z własnych jabłoni i pieczemy szarlotkę. Na Wielkanoc dzieci robią mazurek — prawdziwy, z masą i bakaliami.',
  },
  {
    q: 'Ile kosztuje wyżywienie w przedszkolu?',
    a: 'Wyżywienie jest odrębną opłatą — szczegółowych informacji o kosztach i o tym, co wchodzi w skład czesnego, udzielamy bezpośrednio po kontakcie z przedszkolem. Zapraszamy do rozmowy.',
  },
];
---

<Layout metadata={metadata}>

  <SchemaBreadcrumbs items={[
    { name: 'Strona główna', url: 'https://koloroweprzedszkole.com/' },
    { name: 'O nas', url: 'https://koloroweprzedszkole.com/o-nas/historia' },
    { name: 'Kuchnia', url: 'https://koloroweprzedszkole.com/o-nas/kuchnia' },
  ]} />

  <!-- FAQPage schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

  <!-- ─── Hero (knockout style, trimmed) ─────────────────────── -->
  <!-- Band sits directly under the navbar with no extra padding wrapper —
       PageLayout's main pt-16 already pushes content below the fixed
       navbar on mobile; on desktop the navbar (cream/90 + backdrop-blur)
       gently tints over the top of the band. -->
  <div class="relative">
    <Image
      src={headerMazy}
      alt=""
      aria-hidden="true"
      class="w-full h-40 md:h-52 lg:h-60 object-cover"
      loading="eager"
      fetchpriority="high"
      widths={[768, 1280, 1920]}
      sizes="100vw"
    />

    <!-- Massive lowercase title bleeding below the band edge — the lower
         portion of the letters is cream-on-cream below the band, so it
         visually 'fades' / gets cut by the section divider. No shadow,
         clean knockout. Centered horizontally. -->
    <div class="absolute inset-x-0 bottom-0 pointer-events-none">
      <h1 class="px-6 text-center font-sans font-black text-[clamp(4.5rem,16vw,12rem)] text-brand-cream leading-[0.85] tracking-tight lowercase translate-y-[18%] md:translate-y-[22%]">
        kuchnia
      </h1>
    </div>
  </div>

  <!-- ─── Intro (with scattered-letters background, same pattern as Opinie) ─── -->
  <section class="relative bg-brand-cream py-16 md:py-20 overflow-hidden">

    <!-- Decorative scattered letters, same Adobe Typekit handwritten font -->
    <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
      <span class="absolute text-brand-navy/12 leading-none text-5xl md:text-8xl"   style="top: 8%;  left: 6%;  transform: translate(-50%,-50%) rotate(-32deg); font-family: 'learning-curve', sans-serif;">k</span>
      <span class="absolute text-brand-navy/12 leading-none text-3xl md:text-5xl"   style="top: 14%; left: 18%; transform: translate(-50%,-50%) rotate(22deg); font-family: 'learning-curve', sans-serif;">o</span>
      <span class="absolute text-brand-navy/12 leading-none text-5xl md:text-8xl"   style="top: 12%; left: 88%; transform: translate(-50%,-50%) rotate(28deg); font-family: 'learning-curve', sans-serif;">O</span>
      <span class="absolute text-brand-navy/12 leading-none text-3xl md:text-5xl"   style="top: 50%; left: 4%;  transform: translate(-50%,-50%) rotate(-18deg); font-family: 'learning-curve', sans-serif;">r</span>
      <span class="absolute text-brand-navy/12 leading-none text-3xl md:text-5xl"   style="top: 52%; left: 96%; transform: translate(-50%,-50%) rotate(34deg); font-family: 'learning-curve', sans-serif;">l</span>
      <span class="absolute text-brand-navy/12 leading-none text-5xl md:text-8xl"   style="top: 88%; left: 10%; transform: translate(-50%,-50%) rotate(40deg); font-family: 'learning-curve', sans-serif;">w</span>
      <span class="absolute text-brand-navy/12 leading-none text-3xl md:text-5xl"   style="top: 92%; left: 38%; transform: translate(-50%,-50%) rotate(-22deg); font-family: 'learning-curve', sans-serif;">e</span>
      <span class="absolute text-brand-navy/12 leading-none text-5xl md:text-8xl"   style="top: 90%; left: 82%; transform: translate(-50%,-50%) rotate(-14deg); font-family: 'learning-curve', sans-serif;">k</span>
    </div>

    <div class="relative max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans text-xl text-brand-navy/80 leading-relaxed mb-6">
        <strong class="text-brand-navy">Nasza filozofia kuchni:</strong> gotować tak, jak gotuje się w domu — ze świeżych składników, od lokalnych dostawców, bez kompromisów. Śniadanie, obiad i podwieczorek, każdego dnia, przygotowane na miejscu przez Ciocię Tatianę.
      </p>
      <p class="font-sans text-lg text-brand-navy/60 leading-relaxed mb-6">
        Nie korzystamy z cateringu. Wierzymy, że dziecko, które je prawdziwe domowe jedzenie, czuje się zaopiekowane — i że smak ma znaczenie równie duże jak program.
      </p>
      <p class="font-sans text-base text-brand-navy/55 leading-relaxed italic">
        Gotujemy tak na Saskiej Kępie od 1991 roku — bez kompromisów, bez cateringu.
      </p>
    </div>
  </section>

  <!-- ─── 4 sekcje alternating ─────────────────────────────── -->
  {sekcje.map((s, i) => (
    <section class={i % 2 === 0 ? 'bg-brand-warm' : 'bg-brand-cream'}>
      <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">

          <div class={`rounded-2xl overflow-hidden aspect-[4/3] ${s.flip ? 'md:order-2' : ''}`}>
            <Image
              src={s.img}
              alt={s.alt}
              class="w-full h-full object-cover"
              widths={[640, 960, 1280]}
              sizes="(max-width: 768px) 100vw, 50vw"
            />
          </div>

          <div class={`flex flex-col gap-5 ${s.flip ? 'md:order-1' : ''}`}>
            <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">{s.eyebrow}</p>
            <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
              {s.title}
            </h2>
            <p class="font-sans text-brand-navy/70 text-base leading-relaxed">
              {s.body}
            </p>
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- ─── CTA ──────────────────────────────────────────────── -->
  <section class="bg-brand-navy py-24">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Filozofia kuchni</p>
      <blockquote class="font-sans italic text-[clamp(1.5rem,3vw,2.2rem)] text-brand-cream leading-snug">
        „Kuchnia to nie zaplecze. To część wychowania."
      </blockquote>
      <p class="font-sans text-brand-cream/60 text-base leading-relaxed max-w-lg">
        Dziecko, które je dobrze, ma energię. Dziecko, które widzi jak rośnie marchewka i samo ją zbiera,
        rozumie skąd pochodzi jedzenie. Dziecko, które samo zrobi kanapkę, jest odrobinę bardziej samodzielne.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-2">
        <a
          href="/rekrutacja"
          class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
        >
          Rekrutacja 2026/2027
        </a>
        <a
          href="/kontakt"
          class="inline-block border-2 border-brand-cream/40 text-brand-cream font-sans font-semibold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:border-brand-teal hover:text-brand-teal"
        >
          Zadaj pytanie
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────── -->
  <section class="bg-brand-warm py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">FAQ</p>
      <h2 class="font-sans italic text-[clamp(2rem,3.5vw,3rem)] text-brand-navy leading-tight mb-4">
        Pytania o kuchnię
      </h2>
      <p class="font-sans text-lg text-brand-navy/60 mb-12">
        Odpowiedzi na pytania, które słyszymy najczęściej od rodziców.
      </p>

      <div class="divide-y divide-brand-navy/10">
        {faqItems.map((item, i) => (
          <details class="group py-5" open={i === 0}>
            <summary class="flex justify-between items-start cursor-pointer gap-4 list-none">
              <span class="font-sans text-brand-navy font-semibold text-lg leading-snug group-open:text-brand-teal transition-colors duration-200">
                {item.q}
              </span>
              <span class="flex-shrink-0 mt-1 text-brand-teal text-2xl font-light transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="font-sans mt-4 text-brand-navy/75 leading-relaxed text-base">
              {item.a}
            </p>
          </details>
        ))}
      </div>

    </div>
  </section>

</Layout>
