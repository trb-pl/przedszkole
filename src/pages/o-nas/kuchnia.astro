---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';

import imgTatiana from '~/assets/images/kuchnia-tatiana.jpg';
import imgZupa    from '~/assets/images/kuchnia-zupa.jpg';
import imgNatura  from '~/assets/images/wartosci-natura.jpg';
import imgKanapki from '~/assets/images/kuchnia-kanapki.jpg';

const metadata = {
  title: 'Kuchnia Kolorowego Przedszkola — domowe obiady na Saskiej Kępie',
  description: 'Ciocia Tatiana gotuje każdego dnia od podstaw. Lokalne produkty z Mazowsza, własny ogródek warzywny, menu bez cateringu. Kuchnia Kolorowego Przedszkola na Saskiej Kępie.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/kuchnia',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Kuchnia Kolorowego Przedszkola — domowe obiady na Saskiej Kępie',
    description: 'Ciocia Tatiana gotuje każdego dnia od podstaw. Lokalne produkty z Mazowsza, własny ogródek warzywny, menu bez cateringu.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/kuchnia',
    site_name: 'Kolorowe Przedszkole',
  },
};

const warzywa = ['marchewka','lubczyk','szczypiorek','zielony groszek','pigwa','sałata','pomidorki koktajlowe'];

const sekcje = [
  {
    img: imgTatiana,
    alt: 'Ciocia Tatiana w kuchni Kolorowego Przedszkola',
    eyebrow: 'Przez żołądek do serca',
    title: 'Domowa kuchnia',
    body: 'Każdego ranka Ciocia Tatiana wchodzi do kuchni i gotuje — od podstaw, ze świeżych składników, na cały dzień. Śniadanie, obiad, podwieczorek. Gotuje tak, jak gotuje się w domu: z głową, z sercem i bez kompromisów.\n\nKuchnię regularnie dogląda też Ciocia Ola — założycielka przedszkola. Nie dlatego, że musi. Dlatego, że gotowanie to jej prywatna pasja, wyniesiona z mazureckiego domu rodzinnego. W kuchni Kolorowego Przedszkola czuć to na każdym kroku — i na każdym talerzu.',
    flip: false,
  },
  {
    img: imgZupa,
    alt: 'Zupa gotowana na wywarze w Kolorowym Przedszkolu',
    eyebrow: 'Codziennie na talerzu',
    title: 'Co jest na talerzu',
    body: 'Zależy nam na klasycznej, dobrej kuchni polskiej — pełnej warzyw, pożywnych zup i solidnych dań głównych. Bez polepszaczy, bez gotowych mieszanek, bez skrótów.\n\nGotujemy zupy na wywarze — barszcz, żurek, rosół, krupnik. Mięso i ryby od sprawdzonych, lokalnych dostawców. Warzywa i owoce od mazowieckich rolników — od lat tych samych. Jaja od lokalnych hodowców.\n\nKlasyki, które zawsze znikają z talerzy: makaron z twarogiem i truskawkami, pierogi z białym serkiem i śmietanką. Dzieci poznają też kuchnie świata — jemy hummus, sos boloński, chaczapuri. Ryż z kurczakiem i warzywami w azjatyckim stylu to jeden z największych hitów.',
    flip: true,
  },
  {
    img: imgNatura,
    alt: 'Ogród warzywny przy Kolorowym Przedszkolu na Zakopiańskiej',
    eyebrow: 'Zakopiańska 8',
    title: 'Własny ogródek',
    body: 'Przy Zakopiańskiej 8 mamy ogródek warzywny, z którego część składników trafia prosto do kuchni. Rośnie tam marchewka, lubczyk, szczypiorek, zielony groszek, pigwa, sałata i pomidorki koktajlowe.\n\nDzieci same sadzą, podlewają i zbierają. Wiedzą, jak smakuje pomidor prosto z krzaka — i że smakuje zupełnie inaczej niż ten ze sklepu.',
    flip: false,
  },
  {
    img: imgKanapki,
    alt: 'Dzieci robiące kanapki w Kolorowym Przedszkolu',
    eyebrow: 'Samodzielność przy stole',
    title: 'Dzieci w kuchni',
    body: 'Jedzenie to nie tylko to, co ląduje na talerzu. To też umiejętność — i przyjemność.\n\nStarsze grupy robią sobie kanapki na śniadanie same, ze świeżych składników, według własnego gustu. Jeden woli samą szynkę, drugi koniecznie z ogórkiem i bez masła. Każdy decyduje.\n\nRegularnie pieczemy razem zdrowe ciastka — to stały element programu, nie jednorazowa atrakcja. Na Wielkanoc dzieci robią mazurek: prawdziwy, z masą, z bakaliami. I są z siebie bardzo dumne.',
    flip: true,
  },
];

const faqItems = [
  {
    q: 'Czy Kolorowe Przedszkole korzysta z cateringu?',
    a: 'Nie. Gotujemy na miejscu każdego dnia — od podstaw, ze świeżych składników. Śniadanie, obiad i podwieczorek przygotowuje Ciocia Tatiana, doświadczona kucharka.',
  },
  {
    q: 'Skąd pochodzą produkty używane w kuchni przedszkola?',
    a: 'Warzywa, owoce, jaja i mięso kupujemy od lokalnych rolników z województwa mazowieckiego — od lat u tych samych, sprawdzonych dostawców. Część warzyw pochodzi z własnego ogródka przy Zakopiańskiej 8.',
  },
  {
    q: 'Czy przedszkole uwzględnia alergie pokarmowe?',
    a: 'Tak. Jeśli dziecko ma alergię lub nietolerancję pokarmową, dostosowujemy menu indywidualnie. Ciocia Tatiana wie, co przygotować i jak zadbać o to, żeby dziecko jadło bezpiecznie i smacznie — bez poczucia, że dostaje coś innego niż reszta grupy.',
  },
  {
    q: 'Czy mogę sprawdzić co dziecko je w przedszkolu?',
    a: 'Tak. Menu planujemy co tydzień z wyprzedzeniem i wywieszamy na tablicy ogłoszeń. Rodzice wiedzą, co dziecko jadło i co będzie jadło — bez niespodzianek.',
  },
  {
    q: 'Czy dzieci gotują w przedszkolu?',
    a: 'Tak. Starsze grupy robią sobie kanapki na śniadanie samodzielnie, ze świeżych składników. Regularnie pieczemy razem zdrowe ciastka. Na Wielkanoc dzieci robią mazurek — prawdziwy, z masą i bakaliami.',
  },
];
---

<Layout metadata={metadata}>

  <!-- FAQPage schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(item => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": { "@type": "Answer", "text": item.a }
    }))
  })} />

  <!-- ─── Hero ── identyczny z misja-i-wartości ─────────────── -->
  <section class="relative bg-brand-navy pt-32 pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-brand-navy/70 z-10"></div>
    <img
      src="https://placehold.co/1600x700/2D346F/34BBA8?text=Kuchnia"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative z-20 max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.4rem,6vw,4rem)] text-brand-cream leading-tight mb-6">
        Kuchnia Kolorowego Przedszkola
      </h1>
      <p class="font-sans text-lg text-brand-cream/75 max-w-xl mx-auto leading-relaxed">
        Gotujemy każdego dnia — od podstaw, bez cateringu, bez kompromisów.
      </p>
    </div>
  </section>

  <!-- ─── Intro ─────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans italic text-[clamp(1.4rem,2.5vw,2rem)] text-brand-navy leading-relaxed mb-5">
        W Kolorowym Przedszkolu nie ma cateringu. Nigdy nie było.
      </p>
      <p class="font-sans text-lg text-brand-navy/60 leading-relaxed">
        Każdego ranka Ciocia Tatiana wchodzi do kuchni i gotuje od podstaw,
        ze świeżych składników, na cały dzień.
      </p>
    </div>
  </section>

  <!-- ─── 4 sekcje alternating ── identycznie jak misja ─────── -->
  {sekcje.map((s) => (
    <section class="bg-brand-warm overflow-hidden">
      <div class={`max-w-6xl mx-auto flex flex-col ${s.flip ? 'md:flex-row-reverse' : 'md:flex-row'} items-stretch`}>

        <div class="md:w-1/2 aspect-[4/3] md:aspect-auto overflow-hidden">
          <Image
            src={s.img}
            alt={s.alt}
            class="w-full h-full object-cover"
            widths={[640, 960, 1280]}
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        </div>

        <div class="md:w-1/2 flex items-center px-8 py-14 md:px-14 md:py-20 bg-brand-warm">
          <div>
            <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">{s.eyebrow}</p>
            <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight mb-5">
              {s.title}
            </h2>
            {s.body.split('\n\n').map((para) => (
              <p class="font-sans text-brand-navy/70 text-base leading-relaxed mb-4 last:mb-0">
                {para}
              </p>
            ))}
          </div>
        </div>

      </div>
    </section>
  ))}

  <!-- ─── CTA ───────────────────────────────────────────────── -->
  <section class="bg-brand-navy py-24">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Dlaczego to ważne</p>
      <blockquote class="font-sans italic text-[clamp(1.5rem,3vw,2.2rem)] text-brand-cream leading-snug">
        „Kuchnia to nie zaplecze. To część wychowania."
      </blockquote>
      <p class="font-sans text-brand-cream/60 text-base leading-relaxed max-w-lg">
        Dziecko, które je dobrze, ma energię. Dziecko, które widzi jak rośnie marchewka i samo ją zbiera,
        rozumie skąd pochodzi jedzenie. Dziecko, które samo zrobi kanapkę, jest odrobinę bardziej samodzielne.
      </p>
      <a
        href="tel:605657366"
        class="mt-2 inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
      >
        Zadzwoń i umów wizytę
      </a>
    </div>
  </section>

  <!-- ─── FAQ ───────────────────────────────────────────────── -->
  <section class="bg-brand-warm py-20">
    <div class="max-w-3xl mx-auto px-6">

      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">Pytania i odpowiedzi</p>
      <h2 class="font-sans italic text-[clamp(2rem,3.5vw,3rem)] text-brand-navy leading-tight mb-4">
        Najczęściej zadawane pytania
      </h2>
      <p class="font-sans text-lg text-brand-navy/60 mb-12">
        Odpowiedzi na pytania, które słyszymy najczęściej od rodziców.
      </p>

      <div class="divide-y divide-brand-navy/10">
        {faqItems.map((item, i) => (
          <details class="group py-5" open={i === 0}>
            <summary class="flex justify-between items-start cursor-pointer gap-4 list-none">
              <span class="font-sans text-brand-navy font-semibold text-lg leading-snug group-open:text-brand-teal transition-colors duration-200">
                {item.q}
              </span>
              <span class="flex-shrink-0 mt-1 text-brand-teal text-2xl font-light transition-transform duration-200 group-open:rotate-45">
                +
              </span>
            </summary>
            <p class="font-sans mt-4 text-brand-navy/75 leading-relaxed text-base">
              {item.a}
            </p>
          </details>
        ))}
      </div>

    </div>
  </section>

</Layout>
