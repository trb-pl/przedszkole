---
import { Image } from 'astro:assets';
import Layout from '~/layouts/PageLayout.astro';
import SchemaBreadcrumbs from '~/components/seo/SchemaBreadcrumbs.astro';

import imgMazury      from '~/assets/images/Kolorowe_przedszkole_tarda2.jpg';
import imgOlga        from '~/assets/images/historia-olga.jpg';
import imgAgnieszka   from '~/assets/images/historia-agnieszka.jpg';
import imgAbsolwenci  from '~/assets/images/historia-absolwenci.jpg';

const metadata = {
  title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
  description: 'Od 1991 roku na Saskiej Kępie. Historia Kolorowego Przedszkola — dwóch pokoleń rodziny Trębickich i setek dzieci, które przez lata stały się częścią tej historii.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/historia',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
    description: 'Od 1991 roku na Saskiej Kępie. Historia Kolorowego Przedszkola — dwóch pokoleń rodziny Trębickich i setek dzieci, które przez lata stały się częścią tej historii.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/historia',
    site_name: 'Kolorowe Przedszkole',
  },
};

const sekcje = [
  {
    img: imgMazury,
    alt: 'Olga Trębicka, założycielka Kolorowego Przedszkola',
    eyebrow: 'Skąd się wzięłyśmy',
    title: 'Mazury, szkolna ławka i tata dyrektor',
    body: [
      'Olga Trębicka wychowywała się w Miłomłynie — niewielkiej miejscowości na Mazurach, w wielodzietnej rodzinie. Jej ojciec był dyrektorem małej wiejskiej szkoły, w której mieszkali. Już jako czterolatka całymi dniami przesiadywała w szkolnej ławce — bawiąc się, słuchając i obserwując pracę taty i innych nauczycieli.',
      'Będąc nastolatką, postanowiła wyłamać się z rodzinnego schematu. Wybrała ekonomię. Kilka lat później, po studiach i założeniu własnej rodziny, przekonała się, że pedagogiczna krew jednak w niej płynie.',
    ],
    flip: false,
  },
  {
    img: imgOlga,
    alt: 'Dom przy ulicy Lotaryńskiej 18 — pierwsza siedziba Kolorowego Przedszkola',
    eyebrow: '1991',
    title: 'Dom, który stał się przedszkolem',
    body: [
      'W 1991 roku Olga szukała dla swojej córki Agnieszki miejsca, w którym dziecko poczuje się bezpiecznie i będzie traktowane z uwagą i miłością. Takiego miejsca nie było na mapie Warszawy.',
      'Razem z mężem przystosowała własny dom przy ulicy Lotaryńskiej 18 na Saskiej Kępie. Tak powstało Kolorowe Przedszkole — nie jako biznes, ale jako odpowiedź na potrzebę, którą znała z własnego doświadczenia.',
    ],
    flip: true,
  },
  {
    img: imgAgnieszka,
    alt: 'Agnieszka Trębicka, pedagog i współzałożycielka Kolorowego Przedszkola',
    eyebrow: 'Drugie pokolenie',
    title: 'Agnieszka — pierwsze dziecko, drugi filar',
    body: [
      'W 1991 roku to właśnie dla Agnieszki Trębickiej powstało Kolorowe Przedszkole. Swoje pierwsze doświadczenie zawodowe zdobywała już jako siedmiolatka — wracała ze szkoły i pomagała mamie przy dzieciach.',
      'Ukończyła pedagogikę przedszkolną i wczesnoszkolną na Uniwersytecie Warszawskim. Swoje doświadczenie poszerzała w przedszkolach w Kanadzie, Nowej Zelandii, Australii, Wielkiej Brytanii i Hongkongu. Jest propagatorką pedagogiki Emmi Pikler — podejścia opartego na szacunku dla indywidualnych potrzeb i tempa dziecka.',
      'Dziś Agnieszka jest drugim filarem Kolorowego Przedszkola. Tej samej, którą mama stworzyła kiedyś dla niej.',
    ],
    flip: false,
  },
  {
    img: imgAbsolwenci,
    alt: 'Dzieci w Kolorowym Przedszkolu na Saskiej Kępie',
    eyebrow: 'Absolwenci',
    title: 'Pokolenia, które pamiętamy',
    body: [
      'Przez ponad trzydzieści lat przez Kolorowe Przedszkole przeszły setki dzieci. Dziś są wśród nich profesor Uniwersytetu Warszawskiego pracujący nad zagadnieniami fizyki kwantowej, lekarze, prawnicy, przedsiębiorcy czy trener windsurfingu na Teneryfie.',
      'Śledzimy ich drogi z prawdziwą dumą — bo pamiętamy ich jako trzylatków, którzy po raz pierwszy samodzielnie zawiązali buty. Nasi absolwenci to nasi przyjaciele. Utrzymujemy z nimi kontakt, cieszymy się z ich sukcesów i pielęgnujemy bliskie więzi — przez wszystkie lata, nawet kiedy są już dorośli.',
    ],
    flip: true,
  },
];

---

<Layout metadata={metadata}>

  <SchemaBreadcrumbs items={[
    { name: 'Strona główna', url: 'https://koloroweprzedszkole.com/' },
    { name: 'O nas', url: 'https://koloroweprzedszkole.com/o-nas/historia' },
    { name: 'Historia', url: 'https://koloroweprzedszkole.com/o-nas/historia' },
  ]} />

  <!-- Person schema: builds E-E-A-T signals for the founders. AI engines
       (ChatGPT, Perplexity, Google AI Overviews) cite authoritative people
       by name when answering "kto założył Kolorowe Przedszkole" etc. -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Person",
        "@id": "https://koloroweprzedszkole.com/o-nas/historia#olga",
        "name": "Olga Trębicka",
        "jobTitle": "Założycielka i dyrektor",
        "description": "Założycielka Kolorowego Przedszkola. W 1991 roku zaadaptowała rodzinny dom przy ul. Lotaryńskiej 18 na pierwszą siedzibę przedszkola. Pochodzi z Miłomłyna na Mazurach, gdzie wychowywała się w rodzinie pedagogów.",
        "worksFor": { "@id": "https://koloroweprzedszkole.com/#organization" },
        "founderOf": { "@id": "https://koloroweprzedszkole.com/#organization" }
      },
      {
        "@type": "Person",
        "@id": "https://koloroweprzedszkole.com/o-nas/historia#agnieszka",
        "name": "Agnieszka Trębicka",
        "jobTitle": "Pedagog, drugi filar",
        "description": "Drugie pokolenie Kolorowego Przedszkola. Ukończyła pedagogikę przedszkolną i wczesnoszkolną na Uniwersytecie Warszawskim. Doświadczenie poszerzała w przedszkolach w Kanadzie, Nowej Zelandii, Australii, Wielkiej Brytanii i Hongkongu. Propagatorka pedagogiki Emmi Pikler.",
        "alumniOf": { "@type": "CollegeOrUniversity", "name": "Uniwersytet Warszawski" },
        "worksFor": { "@id": "https://koloroweprzedszkole.com/#organization" }
      }
    ]
  })} />

  <!-- ChildCare details for this page (founding story, addresses) -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ChildCare",
    "name": "Kolorowe Przedszkole",
    "foundingDate": "1991",
    "founder": { "@id": "https://koloroweprzedszkole.com/o-nas/historia#olga" },
    "employee": [
      { "@id": "https://koloroweprzedszkole.com/o-nas/historia#olga" },
      { "@id": "https://koloroweprzedszkole.com/o-nas/historia#agnieszka" }
    ],
    "description": "Rodzinne przedszkole na Saskiej Kępie założone w 1991 roku przez Olgę Trębicką. Dwie lokalizacje: ul. Lotaryńska 18 i ul. Zakopiańska 8.",
    "url": "https://koloroweprzedszkole.com",
    "address": [
      { "@type": "PostalAddress", "streetAddress": "ul. Lotaryńska 18", "postalCode": "03-974", "addressLocality": "Warszawa", "addressCountry": "PL" },
      { "@type": "PostalAddress", "streetAddress": "ul. Zakopiańska 8",  "postalCode": "03-977", "addressLocality": "Warszawa", "addressCountry": "PL" }
    ]
  })} />

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-navy pt-20 pb-12 md:pt-32 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-brand-navy/70 z-10"></div>
    <img
      src="https://placehold.co/1600x700/2D346F/34BBA8?text=Historia"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative z-20 max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.4rem,6vw,4rem)] text-brand-cream leading-tight mb-6">
        Historia Kolorowego Przedszkola
      </h1>
      <p class="font-sans text-lg text-brand-cream/75 max-w-xl mx-auto leading-relaxed">
        Od małej grupki dzieci w domu na Lotaryńskiej do dwóch lokalizacji
        i ponad trzydziestu lat na Saskiej Kępie.
      </p>
    </div>
  </section>

  <!-- ─── Intro ─────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans text-xl text-brand-navy/80 leading-relaxed mb-6">
        <strong class="text-brand-navy">Nasze miejsce:</strong> rodzinny dom Olgi i Tomasza Trębickich przy Lotaryńskiej 18 —
        i właśnie tutaj, w 1991 roku, wszystko się zaczęło.
      </p>
      <p class="font-sans text-lg text-brand-navy/60 leading-relaxed">
        Oficjalnie nasza historia liczy ponad trzydzieści lat. Nieoficjalnie —
        zaczęła się kilkadziesiąt lat wcześniej, w mazurskim Miłomłynie,
        gdzie dyrektor małej wiejskiej szkoły miał czteroletnią córkę, która całymi dniami
        siedziała w szkolnej ławce i obserwowała.
      </p>
    </div>
  </section>

  <!-- ─── 4 sekcje narracyjne (alternating) ────────────────── -->
  {sekcje.map((s, i) => (
    <section class={i % 2 === 0 ? 'bg-brand-warm' : 'bg-brand-cream'}>
      <div class="max-w-6xl mx-auto px-6 py-12 md:py-16">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center">

          <div class={`rounded-2xl overflow-hidden aspect-[4/3] ${s.flip ? 'md:order-2' : ''}`}>
            <Image src={s.img} alt={s.alt} class="w-full h-full object-cover" widths={[640, 960, 1280]} sizes="(max-width: 768px) 100vw, 50vw" />
          </div>

          <div class={`flex flex-col gap-5 ${s.flip ? 'md:order-1' : ''}`}>
            <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">{s.eyebrow}</p>
            <h2 class="font-sans italic text-[clamp(1.8rem,3vw,2.6rem)] text-brand-navy leading-tight">
              {s.title}
            </h2>
            {s.body.map(para => (
              <p class="font-sans text-brand-navy/70 text-base leading-relaxed">{para}</p>
            ))}
          </div>

        </div>
      </div>
    </section>
  ))}

  <!-- ─── Co się nie zmienia (granatowe) ─────────────────── -->
  <section class="bg-brand-navy py-24">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Co się nie zmienia</p>
      <h2 class="font-sans italic text-[clamp(1.8rem,3.5vw,2.8rem)] text-brand-cream leading-snug">
        Domowa atmosfera — od zawsze
      </h2>
      <p class="font-sans text-brand-cream/70 text-lg leading-relaxed max-w-xl">
        Lata mijają, metody się rozwijają, lokalizacji przybywa. Ale jedno
        pozostaje niezmienne: domowa, rodzinna atmosfera, luz i bliskość
        w pracy z dziećmi i ich rodzicami.
      </p>
      <a
        href="/rekrutacja"
        class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
      >
        Rekrutacja 2026/2027
      </a>
    </div>
  </section>

  <!-- ─── CTA (jasne tło) ──────────────────────────────────── -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Zapraszamy</p>
      <h2 class="font-sans italic text-[clamp(1.8rem,3.5vw,2.8rem)] text-brand-navy leading-snug">
        Bądź częścią naszej historii
      </h2>
      <p class="font-sans text-brand-navy/70 text-lg leading-relaxed max-w-xl">
        Chcemy, żeby pobyt w Kolorowym Przedszkolu dawał dzieciom najlepszy start
        i przygotowanie do dalszej drogi — nie tylko szkolnej, ale i życiowej.
        Jeśli podoba Ci się nasza historia i czujesz, że to miejsce stworzone
        dla Twojego dziecka — odezwij się. Możesz napisać, zadzwonić albo
        po prostu przyjść. Koniecznie z dzieckiem.
      </p>
      <a
        href="tel:605657366"
        class="inline-block border-2 border-brand-navy/30 text-brand-navy font-sans font-semibold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:border-brand-teal hover:text-brand-teal"
      >
        Zadzwoń i przyjdź z dzieckiem
      </a>
    </div>
  </section>

</Layout>
