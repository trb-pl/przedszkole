---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
  description: 'Poznaj historię Kolorowego Przedszkola na Saskiej Kępie. Od 1991 roku budujemy bezpieczny pomost między domem a szkołą dla rodzin z Saskiej Kępy i Gocławia.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/historia',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
    description: 'Poznaj historię Kolorowego Przedszkola na Saskiej Kępie. Od 1991 roku budujemy bezpieczny pomost między domem a szkołą dla rodzin z Saskiej Kępy i Gocławia.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/historia',
    site_name: 'Kolorowe Przedszkole',
  },
};

const milestones = [
  {
    year: '1991',
    title: 'Początki przy Lotaryńskiej',
    body: 'Olga Trębicka otwiera pierwsze Kolorowe Przedszkole w kamienicy przy ul. Lotaryńskiej 18 na Saskiej Kępie. Pierwsza grupa liczy zaledwie dwanaścioro dzieci — i jedną ogromną pasję do wychowania.',
  },
  {
    year: '1997',
    title: 'Pierwsze rozszerzenie',
    body: 'Rosnące zainteresowanie rodziców sprawia, że otwieramy drugą grupę. Remontujemy kolejne sale, powiększamy ogród i zatrudniamy pierwszą logopedę.',
  },
  {
    year: '2004',
    title: 'Metody Montessori i Pikler',
    body: 'Cały zespół pedagogiczny przechodzi intensywne szkolenia. Wdrażamy elementy pedagogiki Marii Montessori i filozofii Emmi Pikler — szacunek do tempa dziecka staje się fundamentem naszej pracy.',
  },
  {
    year: '2009',
    title: 'Własna kuchnia',
    body: 'Rezygnujemy z zewnętrznego cateringu i otwieramy własną kuchnię. Od tej pory każdy posiłek jest przygotowywany na miejscu, ze świeżych składników, przez naszą kucharkę.',
  },
  {
    year: '2014',
    title: 'Zakopiańska 8 — nowa lokalizacja',
    body: 'Otwieramy drugą placówkę przy ul. Zakopiańskiej 8. Willa z ogromnym ogrodem staje się domem dla starszych grup. Powstaje sala Integracji Sensorycznej (SI) i gabinet psychologiczno-logopedyczny.',
  },
  {
    year: '2018',
    title: 'Angielski przez cały dzień',
    body: 'Zatrudniamy opiekunki anglojęzyczne, które mówią do dzieci wyłącznie po angielsku przez cały dzień. Koniec z lekcjami z kartami pracy — zaczyna się naturalna immersja językowa.',
  },
  {
    year: '2024',
    title: 'Ponad 30 lat i kolejne pokolenia',
    body: 'Do Kolorowego Przedszkola zaczynają trafiać dzieci absolwentów z lat 90. Ponad 30 lat obecności na Saskiej Kępie to dla nas nie sentyment — to zobowiązanie.',
  },
];
---

<Layout metadata={metadata}>

  <!-- Header -->
  <section class="bg-brand-warm pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.2rem,5vw,3.5rem)] text-brand-navy leading-tight mb-5">
        Historia Kolorowego Przedszkola
      </h1>
      <p class="font-sans text-lg text-brand-navy/60 max-w-xl mx-auto">
        Od małej grupki dzieci w kamienicy na Lotaryńskiej do dwóch pełnych lokalizacji —
        ponad 30 lat budowania bezpiecznego pomostu między domem a szkołą.
      </p>
    </div>
  </section>

  <!-- Timeline -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-4xl mx-auto px-6">

      <div class="relative">

        <!-- Vertical line -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-brand-navy/15 -translate-x-px md:-translate-x-px"></div>

        <div class="flex flex-col gap-0">
          {milestones.map((m, i) => {
            const isRight = i % 2 === 0; // desktop: even = left card, odd = right card
            return (
              <div class={`relative flex items-start gap-0 md:gap-8 mb-12
                /* mobile: always left-line + card on right */
                pl-12 md:pl-0
                /* desktop: alternate sides */
                ${isRight ? 'md:flex-row' : 'md:flex-row-reverse'}
              `}>

                <!-- Dot on the line -->
                <div class="absolute left-4 md:left-1/2 top-1.5 w-3 h-3 rounded-full bg-brand-teal border-2 border-brand-cream -translate-x-1/2 z-10 shrink-0"></div>

                <!-- Card — takes half width on desktop -->
                <div class={`w-full md:w-[calc(50%-2rem)] bg-white rounded-2xl px-7 py-6 shadow-sm border border-brand-navy/6
                  ${isRight ? 'md:mr-auto' : 'md:ml-auto'}
                `}>
                  <span class="font-sans font-bold text-brand-teal text-sm uppercase tracking-widest mb-2 block">
                    {m.year}
                  </span>
                  <h2 class="font-sans font-bold text-brand-navy text-xl mb-3 leading-snug">
                    {m.title}
                  </h2>
                  <p class="font-sans text-brand-navy/65 text-base leading-relaxed">
                    {m.body}
                  </p>
                </div>

              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-brand-warm py-16">
    <div class="max-w-xl mx-auto px-6 text-center flex flex-col items-center gap-5">
      <p class="font-sans italic text-[clamp(1.5rem,3vw,2.2rem)] text-brand-navy leading-tight">
        Chcesz być częścią tej historii?
      </p>
      <a
        href="/rekrutacja"
        class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
      >
        Rekrutacja 2026/2027
      </a>
    </div>
  </section>

</Layout>
