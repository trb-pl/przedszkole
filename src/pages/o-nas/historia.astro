---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
  description: 'Od 1991 roku na Saskiej Kępie. Historia Kolorowego Przedszkola — dwóch pokoleń rodziny Trębickich i setek dzieci, które przez lata stały się częścią tej historii.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/historia',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Historia Kolorowego Przedszkola — Od 1991 roku | Saska Kępa',
    description: 'Od 1991 roku na Saskiej Kępie. Historia Kolorowego Przedszkola — dwóch pokoleń rodziny Trębickich i setek dzieci, które przez lata stały się częścią tej historii.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/historia',
    site_name: 'Kolorowe Przedszkole',
  },
};

const milestones = [
  {
    year: '1991',
    title: 'Początki przy Lotaryńskiej',
    body: 'Olga Trębicka nie mogła znaleźć dla swojej córki Agnieszki miejsca, w którym dziecko poczuje się bezpiecznie i będzie traktowane z uwagą. Takiego miejsca nie było na mapie Warszawy.\n\nRazem z mężem przystosowała własny dom przy ulicy Lotaryńskiej 18 na Saskiej Kępie. Tak powstało Kolorowe Przedszkole — nie jako biznes, ale jako odpowiedź na potrzebę, którą znała z własnego doświadczenia.\n\nPierwsza grupa: dwanaścioro dzieci. I jedna ogromna pasja do wychowania.',
  },
  {
    year: '1997',
    title: 'Pierwsze rozszerzenie',
    body: 'Rosnące zainteresowanie rodziców sprawia, że otwieramy drugą grupę. Remontujemy kolejne sale, powiększamy ogród i zatrudniamy pierwszą logopedę.',
  },
  {
    year: '2004',
    title: 'Montessori, Pikler, Korczak',
    body: 'Cały zespół pedagogiczny przechodzi intensywne szkolenia. Wdrażamy elementy pedagogiki Marii Montessori, filozofii Emmi Pikler i myśli Janusza Korczaka. Szacunek do indywidualnego tempa dziecka staje się fundamentem naszej pracy — i pozostaje nim do dziś.',
  },
  {
    year: '2009',
    title: 'Własna kuchnia',
    body: 'Rezygnujemy z zewnętrznego cateringu i otwieramy własną kuchnię. Od tej pory każdy posiłek jest przygotowywany na miejscu, ze świeżych składników. Bez kompromisów.',
  },
  {
    year: '2018',
    title: 'Angielski przez cały dzień',
    body: 'Zatrudniamy opiekunki anglojęzyczne, które mówią do dzieci wyłącznie po angielsku przez większą część dnia. Koniec z lekcjami z kartami pracy — zaczyna się naturalny kontakt z językiem od najmłodszych lat.',
  },
  {
    year: '2020',
    title: 'Zakopiańska 8 — druga lokalizacja',
    body: 'Olga i Agnieszka Trębicka otwierają drugą placówkę przy ul. Zakopiańskiej 8. Willa z ogrodem ponad 1200 m² staje się domem dla starszych grup. Powstaje sala Integracji Sensorycznej i gabinet psychologiczny.\n\nDwie lokalizacje, jedna filozofia.',
  },
  {
    year: '2024',
    title: 'Drugie pokolenie — i kolejne',
    body: 'Do Kolorowego Przedszkola zaczynają trafiać dzieci absolwentów z lat 90. Wśród naszych wychowanków są dziś profesor Uniwersytetu Warszawskiego pracujący nad fizyką kwantową, lekarze, prawnicy, przedsiębiorcy i zawodowy windsurfer.\n\nPonad 30 lat obecności na Saskiej Kępie to dla nas nie sentyment. To zobowiązanie.',
  },
];
---

<Layout metadata={metadata}>

  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ChildCare",
    "name": "Kolorowe Przedszkole",
    "foundingDate": "1991",
    "founder": {
      "@type": "Person",
      "name": "Olga Trębicka"
    },
    "description": "Rodzinne przedszkole na Saskiej Kępie, założone w 1991 roku przez Olgę Trębicką. Dwie lokalizacje: ul. Lotaryńska 18 i ul. Zakopiańska 8.",
    "url": "https://koloroweprzedszkole.com",
    "address": [
      {
        "@type": "PostalAddress",
        "streetAddress": "ul. Lotaryńska 18",
        "postalCode": "03-974",
        "addressLocality": "Warszawa",
        "addressCountry": "PL"
      },
      {
        "@type": "PostalAddress",
        "streetAddress": "ul. Zakopiańska 8",
        "postalCode": "03-977",
        "addressLocality": "Warszawa",
        "addressCountry": "PL"
      }
    ]
  })} />

  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="relative bg-brand-navy pt-20 pb-12 md:pt-32 md:pb-24 overflow-hidden">
    <div class="absolute inset-0 bg-brand-navy/70 z-10"></div>
    <img
      src="https://placehold.co/1600x700/2D346F/34BBA8?text=Historia"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 w-full h-full object-cover opacity-20"
    />
    <div class="relative z-20 max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.4rem,6vw,4rem)] text-brand-cream leading-tight mb-6">
        Historia Kolorowego Przedszkola
      </h1>
      <p class="font-sans text-lg text-brand-cream/75 max-w-xl mx-auto leading-relaxed">
        Od małej grupki dzieci w domu na Lotaryńskiej do dwóch lokalizacji
        i ponad trzydziestu lat na Saskiej Kępie.
      </p>
    </div>
  </section>

  <!-- ─── Intro ─────────────────────────────────────────────── -->
  <section class="bg-brand-cream py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="font-sans text-xl text-brand-navy/80 leading-relaxed mb-6">
        <strong class="text-brand-navy">Nasze miejsce:</strong> rodzinny dom Olgi i Tomasza Trębickich przy Lotaryńskiej 18 —
        i właśnie tutaj, w 1991 roku, wszystko się zaczęło.
      </p>
      <p class="font-sans text-lg text-brand-navy/60 leading-relaxed">
        Oficjalnie nasza historia liczy ponad trzydzieści lat. Nieoficjalnie —
        zaczęła się kilkadziesiąt lat wcześniej, w mazurskim Miłomłynie,
        gdzie mały dyrektor szkoły miał czteroletnią córkę,
        która całymi dniami siedziała w szkolnej ławce i obserwowała.
      </p>
    </div>
  </section>

  <!-- ─── Timeline ─────────────────────────────────────────── -->
  <section class="bg-brand-warm py-20">
    <div class="max-w-4xl mx-auto px-6">
      <div class="relative">

        <!-- Linia pionowa -->
        <div class="absolute left-4 md:left-1/2 top-0 bottom-0 w-px bg-brand-navy/15 -translate-x-px"></div>

        <div class="flex flex-col gap-0">
          {milestones.map((m, i) => {
            const isRight = i % 2 === 0;
            return (
              <div class={`relative flex items-start gap-0 md:gap-8 mb-12 pl-12 md:pl-0 ${isRight ? 'md:flex-row' : 'md:flex-row-reverse'}`}>

                <!-- Kropka -->
                <div class="absolute left-4 md:left-1/2 top-1.5 w-3 h-3 rounded-full bg-brand-teal border-2 border-brand-warm -translate-x-1/2 z-10 shrink-0"></div>

                <!-- Karta -->
                <div class={`w-full md:w-[calc(50%-2rem)] bg-white rounded-2xl px-7 py-6 shadow-sm border border-brand-navy/6 ${isRight ? 'md:mr-auto' : 'md:ml-auto'}`}>
                  <span class="font-sans font-bold text-brand-teal text-sm uppercase tracking-widest mb-2 block">
                    {m.year}
                  </span>
                  <h2 class="font-sans font-bold text-brand-navy text-xl mb-3 leading-snug">
                    {m.title}
                  </h2>
                  {m.body.split('\n\n').map(para => (
                    <p class="font-sans text-brand-navy/65 text-base leading-relaxed mb-3 last:mb-0">
                      {para}
                    </p>
                  ))}
                </div>

              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>

  <!-- ─── Sekcja zamykająca ────────────────────────────────── -->
  <section class="bg-brand-navy py-24">
    <div class="max-w-3xl mx-auto px-6 text-center flex flex-col items-center gap-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal">Co się nie zmienia</p>
      <h2 class="font-sans italic text-[clamp(1.8rem,3.5vw,2.8rem)] text-brand-cream leading-snug">
        Co się nie zmienia
      </h2>
      <p class="font-sans text-brand-cream/70 text-lg leading-relaxed max-w-xl">
        Lata mijają, metody się rozwijają, lokalizacji przybywa.
        Ale jedno pozostaje niezmienne: domowa, rodzinna atmosfera, luz
        i bliskość w pracy z dziećmi i ich rodzicami.
        Dbamy o to świadomie — bo wiemy, że tego nie można kupić ani zastąpić programem.
      </p>
      <p class="font-sans text-brand-cream/50 text-base leading-relaxed max-w-xl">
        Chcemy, żeby pobyt w Kolorowym Przedszkolu dawał dzieciom najlepszy start
        i przygotowanie do dalszej drogi — nie tylko szkolnej, ale i życiowej.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 mt-4">
        <a
          href="/rekrutacja"
          class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
        >
          Rekrutacja 2026/2027
        </a>
        <a
          href="tel:605657366"
          class="inline-block border-2 border-brand-cream/40 text-brand-cream font-sans font-semibold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:border-brand-teal hover:text-brand-teal"
        >
          Zadzwoń i przyjdź z dzieckiem
        </a>
      </div>
    </div>
  </section>

</Layout>
