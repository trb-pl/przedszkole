---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Misja i Wartości — Kolorowe Przedszkole Saska Kępa',
  description: 'Poznaj misję i wartości Kolorowego Przedszkola na Saskiej Kępie. Inspirujemy się metodami Montessori, Steinera, Korczaka i Pikler — z myślą o harmonijnym rozwoju każdego dziecka.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/misja-i-wartosci',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Misja i Wartości — Kolorowe Przedszkole Saska Kępa',
    description: 'Poznaj misję i wartości Kolorowego Przedszkola na Saskiej Kępie. Inspirujemy się metodami Montessori, Steinera, Korczaka i Pikler — z myślą o harmonijnym rozwoju każdego dziecka.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/misja-i-wartosci',
    site_name: 'Kolorowe Przedszkole',
  },
};
---

<Layout metadata={metadata}>
  <section class="bg-brand-warm pt-24 pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.2rem,5vw,3.5rem)] text-brand-navy leading-tight mb-6">
        Misja i Wartości
      </h1>
      <p class="font-sans text-lg text-brand-navy/60">Treść tej strony jest w przygotowaniu.</p>
    </div>
  </section>
</Layout>
