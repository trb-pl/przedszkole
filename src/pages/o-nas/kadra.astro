---
import Layout from '~/layouts/PageLayout.astro';
import SchemaBreadcrumbs from '~/components/seo/SchemaBreadcrumbs.astro';

const metadata = {
  title: 'Kadra Kolorowego Przedszkola — Nauczyciele i Wychowawcy | Saska Kępa',
  description: 'Poznaj zespół Kolorowego Przedszkola na Saskiej Kępie. Doświadczeni pedagodzy, wychowawcy i specjaliści, którzy tworzą bezpieczne środowisko dla dzieci od 1991 roku.',
  canonical: 'https://koloroweprzedszkole.com/o-nas/kadra',
  ignoreTitleTemplate: true,
  robots: { index: true, follow: true },
  openGraph: {
    title: 'Kadra Kolorowego Przedszkola — Nauczyciele i Wychowawcy | Saska Kępa',
    description: 'Poznaj zespół Kolorowego Przedszkola na Saskiej Kępie. Doświadczeni pedagodzy, wychowawcy i specjaliści, którzy tworzą bezpieczne środowisko dla dzieci od 1991 roku.',
    type: 'website',
    url: 'https://koloroweprzedszkole.com/o-nas/kadra',
    site_name: 'Kolorowe Przedszkole',
  },
};
---

<Layout metadata={metadata}>

  <SchemaBreadcrumbs items={[
    { name: 'Strona główna', url: 'https://koloroweprzedszkole.com/' },
    { name: 'O nas', url: 'https://koloroweprzedszkole.com/o-nas/historia' },
    { name: 'Kadra', url: 'https://koloroweprzedszkole.com/o-nas/kadra' },
  ]} />
  <section class="bg-brand-warm pt-24 pb-20">
    <div class="max-w-3xl mx-auto px-6">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-4">O nas</p>
      <h1 class="font-sans italic text-[clamp(2.2rem,5vw,3.5rem)] text-brand-navy leading-tight mb-6">
        Kadra Kolorowego Przedszkola
      </h1>
      <p class="font-sans text-lg text-brand-navy/60">Treść tej strony jest w przygotowaniu.</p>
    </div>
  </section>
</Layout>
