---
import type { ImageMetadata } from 'astro';
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

import { getPermalink } from '~/utils/permalinks';
import { findImage } from '~/utils/images';
import { getFormattedDate } from '~/utils/utils';

export interface Props {
  post: Post;
}

const { post } = Astro.props;
const image = (await findImage(post.image)) as ImageMetadata | undefined;

const link = APP_BLOG?.post?.isEnabled ? getPermalink(post.permalink, 'post') : '';
---

<article class="bg-white rounded-2xl overflow-hidden shadow-sm border border-brand-navy/5 flex flex-col md:flex-row gap-0 transition-shadow duration-200 hover:shadow-md">

  {image && (
    <a href={link || undefined} class="block md:w-2/5 shrink-0">
      <div class="aspect-[4/3] md:aspect-auto md:h-full overflow-hidden">
        <Image
          src={image}
          class="w-full h-full object-cover transition-transform duration-300 hover:scale-105"
          widths={[400, 800]}
          width={800}
          height={600}
          sizes="(max-width: 768px) 100vw, 400px"
          alt={post.title}
          format="webp"
          loading="lazy"
          decoding="async"
        />
      </div>
    </a>
  )}

  <div class="flex flex-col gap-4 p-7 justify-center">
    <div class="flex items-center gap-2 font-sans text-xs font-bold uppercase tracking-widest text-brand-teal">
      <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
      {post.category && (
        <>
          <span class="text-brand-navy/20">·</span>
          <span>{post.category.title}</span>
        </>
      )}
    </div>

    <h2 class="font-sans font-bold text-xl md:text-2xl text-brand-navy leading-snug">
      {link ? (
        <a href={link} class="hover:text-brand-teal transition-colors duration-200">
          {post.title}
        </a>
      ) : (
        post.title
      )}
    </h2>

    {post.excerpt && (
      <p class="font-sans text-brand-navy/65 text-base leading-relaxed">
        {post.excerpt}
      </p>
    )}

    {link && (
      <a
        href={link}
        class="self-start font-sans font-bold uppercase tracking-wider text-xs text-brand-teal hover:text-brand-coral transition-colors duration-200 mt-1"
      >
        Czytaj dalej →
      </a>
    )}
  </div>

</article>
