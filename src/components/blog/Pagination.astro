---
export interface Props {
  prevUrl?: string;
  nextUrl?: string;
  prevText?: string;
  nextText?: string;
}

const { prevUrl, nextUrl, prevText = '← Nowsze', nextText = 'Starsze →' } = Astro.props;
---

{
  (prevUrl || nextUrl) && (
    <div class="flex justify-between mt-12 pt-8 border-t border-brand-navy/10">
      {prevUrl ? (
        <a
          href={prevUrl}
          class="font-sans font-bold uppercase tracking-wider text-sm text-brand-navy/50 hover:text-brand-teal transition-colors duration-200"
        >
          {prevText}
        </a>
      ) : <span />}
      {nextUrl ? (
        <a
          href={nextUrl}
          class="font-sans font-bold uppercase tracking-wider text-sm text-brand-navy/50 hover:text-brand-teal transition-colors duration-200"
        >
          {nextText}
        </a>
      ) : <span />}
    </div>
  )
}
