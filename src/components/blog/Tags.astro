---
import { getPermalink } from '~/utils/permalinks';
import { APP_BLOG } from 'astrowind:config';
import type { Post } from '~/types';

export interface Props {
  tags: Post['tags'];
  class?: string;
  title?: string | undefined;
  isCategory?: boolean;
}

const { tags, class: className = '', title = undefined, isCategory = false } = Astro.props;
---

{
  tags && Array.isArray(tags) && (
    <div class={`flex flex-wrap gap-2 ${className}`}>
      {title && (
        <span class="font-sans text-xs font-bold uppercase tracking-widest text-brand-navy/40 self-center mr-1">
          {title}
        </span>
      )}
      {tags.map((tag) => (
        <span class="font-sans text-xs font-semibold uppercase tracking-wider bg-brand-sand text-brand-navy/60 px-3 py-1 rounded-full">
          {!APP_BLOG?.tag?.isEnabled ? (
            tag.title
          ) : (
            <a
              href={getPermalink(tag.slug, isCategory ? 'category' : 'tag')}
              class="hover:text-brand-teal transition-colors duration-200"
            >
              {tag.title}
            </a>
          )}
        </span>
      ))}
    </div>
  )
}
