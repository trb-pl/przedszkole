---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;

// Resolve image URL for JSON-LD (must be absolute)
const rawImage = post.image;
let schemaImageUrl = 'https://koloroweprzedszkole.com/og-image.jpg';
if (rawImage) {
  if (typeof rawImage === 'string') {
    schemaImageUrl = rawImage.startsWith('http')
      ? rawImage
      : `https://koloroweprzedszkole.com${rawImage}`;
  } else {
    // ImageMetadata
    schemaImageUrl = rawImage.src.startsWith('http')
      ? rawImage.src
      : `https://koloroweprzedszkole.com${rawImage.src}`;
  }
}

const publishedISO = post.publishDate.toISOString();
const modifiedISO = (post.updateDate ?? post.publishDate).toISOString();
const publishedDate = post.publishDate.toISOString().slice(0, 10);
const canonicalUrl = String(url);
---

<!-- Article JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.title,
  "description": post.excerpt ?? '',
  "image": schemaImageUrl,
  "datePublished": publishedISO,
  "dateModified": modifiedISO,
  "url": canonicalUrl,
  "inLanguage": "pl",
  "author": {
    "@type": "Person",
    "name": "Olga Trębicka",
    "jobTitle": "Założycielka i dyrektor Kolorowego Przedszkola",
    "description": "Założycielka Kolorowego Przedszkola na Saskiej Kępie. Od 1991 roku tworzy środowisko edukacyjne oparte na metodach Montessori, Steinera, Korczaka i Pikler.",
    "sameAs": ["https://www.instagram.com/koloroweprzedszkole"]
  },
  "publisher": {
    "@type": "Organization",
    "name": "Kolorowe Przedszkole",
    "url": "https://koloroweprzedszkole.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://koloroweprzedszkole.com/logo.svg"
    }
  }
})} />

<!-- Cały artykuł na bg-brand-cream, header z większym paddingiem top -->
<article class="bg-brand-cream">

  <!-- Nagłówek -->
  <header class="max-w-3xl mx-auto px-6 pt-28 pb-10">
    <div class="flex items-center gap-2 font-sans text-xs font-bold uppercase tracking-widest text-brand-teal mb-3">
      <time datetime={publishedDate}>{getFormattedDate(post.publishDate)}</time>
      {post.category && (
        <>
          <span class="text-brand-navy/20">·</span>
          <span>{post.category.title}</span>
        </>
      )}
      {post.readingTime && (
        <>
          <span class="text-brand-navy/20">·</span>
          <span>{post.readingTime} min czytania</span>
        </>
      )}
    </div>

    <!-- Author byline -->
    <p class="font-sans text-xs text-brand-navy/40 mb-5">
      <a href="/#olga" class="hover:text-brand-teal transition-colors duration-200">
        Olga Trębicka
      </a>
      {' '}— założycielka Kolorowego Przedszkola
    </p>

    <h1 class="font-sans italic text-[clamp(2rem,4vw,3.2rem)] leading-tight text-brand-navy mb-6">
      {post.title}
    </h1>

    {post.excerpt && (
      <p class="font-sans text-xl text-brand-navy/60 leading-relaxed">
        {post.excerpt}
      </p>
    )}
  </header>

  <!-- Zdjęcie — pełna szerokość max-w-3xl, opakowane w figure -->
  {post.image && (
    <div class="max-w-3xl mx-auto px-6 pb-10">
      <figure class="rounded-2xl overflow-hidden">
        <Image
          src={post.image}
          class="w-full aspect-[16/9] object-cover"
          widths={[800, 1200]}
          sizes="(max-width: 900px) 800px, 1200px"
          alt={post.title}
          width={1200}
          height={675}
          format="webp"
          loading="eager"
          decoding="async"
        />
        <figcaption class="sr-only">{post.title}</figcaption>
      </figure>
    </div>
  )}

  <!-- Treść -->
  <div class="max-w-3xl mx-auto px-6 pb-20">
    <div class="prose prose-lg max-w-none
      prose-headings:font-sans prose-headings:font-bold prose-headings:text-brand-navy prose-headings:not-italic
      prose-h2:text-2xl prose-h3:text-xl
      prose-p:font-sans prose-p:text-brand-navy/75 prose-p:leading-relaxed
      prose-a:text-brand-teal prose-a:no-underline hover:prose-a:text-brand-coral
      prose-strong:text-brand-navy prose-strong:font-bold
      prose-li:font-sans prose-li:text-brand-navy/75
      prose-ul:my-4 prose-ol:my-4
      prose-hr:border-brand-navy/10
      prose-blockquote:border-l-4 prose-blockquote:border-brand-teal prose-blockquote:text-brand-navy/60 prose-blockquote:not-italic
    ">
      <slot />
    </div>

    <!-- Tagi -->
    {post.tags && Array.isArray(post.tags) && post.tags.length > 0 && (
      <div class="mt-12 pt-8 border-t border-brand-navy/10">
        <PostTags tags={post.tags} />
      </div>
    )}

    <!-- Nawigacja dół -->
    <div class="mt-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <a
        href="/porady"
        class="font-sans text-sm font-bold uppercase tracking-wider text-brand-navy/40 hover:text-brand-teal transition-colors duration-200"
      >
        ← Wszystkie porady
      </a>
      <a
        href="/kontakt"
        class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-7 py-3 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
      >
        Skontaktuj się z nami
      </a>
    </div>
  </div>

</article>
