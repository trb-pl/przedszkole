---
import Image from '~/components/common/Image.astro';
import PostTags from '~/components/blog/Tags.astro';

import { getFormattedDate } from '~/utils/utils';
import type { Post } from '~/types';

export interface Props {
  post: Post;
  url: string | URL;
}

const { post, url } = Astro.props;
---

<!-- Header hero sekcja -->
<section class="bg-brand-sand pt-24 pb-12">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Meta -->
    <div class="flex items-center gap-2 font-sans text-xs font-bold uppercase tracking-widest text-brand-teal mb-4">
      <time datetime={String(post.publishDate)}>{getFormattedDate(post.publishDate)}</time>
      {post.category && (
        <>
          <span class="text-brand-navy/20">·</span>
          <span>{post.category.title}</span>
        </>
      )}
      {post.readingTime && (
        <>
          <span class="text-brand-navy/20">·</span>
          <span>{post.readingTime} min czytania</span>
        </>
      )}
    </div>

    <!-- Tytuł -->
    <h1 class="font-sans italic text-[clamp(2rem,4vw,3.2rem)] leading-tight text-brand-navy mb-6">
      {post.title}
    </h1>

    <!-- Excerpt -->
    {post.excerpt && (
      <p class="font-sans text-xl text-brand-navy/65 leading-relaxed">
        {post.excerpt}
      </p>
    )}

  </div>
</section>

<!-- Zdjęcie -->
{post.image && (
  <section class="bg-brand-cream py-10">
    <div class="max-w-3xl mx-auto px-6">
      <div class="rounded-2xl overflow-hidden aspect-[16/9]">
        <Image
          src={post.image}
          class="w-full h-full object-cover"
          widths={[800, 1200]}
          sizes="(max-width: 900px) 800px, 1200px"
          alt={post.excerpt || post.title}
          width={1200}
          height={675}
          format="webp"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </section>
)}

<!-- Treść artykułu -->
<section class="bg-brand-cream pb-16">
  <div class="max-w-3xl mx-auto px-6">
    <div
      class="prose prose-lg max-w-none
        prose-headings:font-sans prose-headings:font-bold prose-headings:text-brand-navy prose-headings:italic
        prose-p:font-sans prose-p:text-brand-navy/75 prose-p:leading-relaxed
        prose-a:text-brand-teal prose-a:no-underline hover:prose-a:text-brand-coral
        prose-strong:text-brand-navy
        prose-li:font-sans prose-li:text-brand-navy/75
        prose-hr:border-brand-navy/10
        prose-blockquote:border-brand-teal prose-blockquote:text-brand-navy/70
        mt-8"
    >
      <slot />
    </div>

    <!-- Tagi -->
    {post.tags && Array.isArray(post.tags) && post.tags.length > 0 && (
      <div class="mt-12 pt-8 border-t border-brand-navy/10">
        <PostTags tags={post.tags} />
      </div>
    )}

    <!-- Powrót + CTA -->
    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <a
        href="/blog"
        class="font-sans text-sm font-bold uppercase tracking-wider text-brand-navy/50 hover:text-brand-teal transition-colors duration-200"
      >
        ← Wszystkie porady
      </a>
      <a
        href="/kontakt"
        class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-7 py-3 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
      >
        Skontaktuj się z nami
      </a>
    </div>
  </div>
</section>
