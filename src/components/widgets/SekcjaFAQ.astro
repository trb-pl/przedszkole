---
const pytania = [
  {
    q: 'Od ilu lat działa Kolorowe Przedszkole?',
    a: 'Kolorowe Przedszkole działa od 1991 roku i jest jednym z najstarszych niepublicznych przedszkoli w Warszawie. Przez ponad 30 lat wypracowaliśmy model opieki, który łączy profesjonalizm z domowym ciepłem – dwie lokalizacje na Saskiej Kępie, tuż przy Gocławiu.',
  },
  {
    q: 'Gdzie znajduje się przedszkole?',
    a: 'Prowadzimy dwie lokalizacje w Warszawie, obie na Saskiej Kępie – tuż przy Gocławiu, w dzielnicy Praga Południe. Każda z nich ma własny ogród i pełną infrastrukturę.',
  },
  {
    q: 'Czy jest sala integracji sensorycznej (SI)?',
    a: 'Tak. Sala SI to jeden z naszych wyróżników – specjalnie wyposażone pomieszczenie wspierające wszechstronny rozwój zmysłów dziecka. Korzystają z niej wszystkie grupy w ramach codziennego programu.',
  },
  {
    q: 'Czy macie własną kuchnię i domowe obiady?',
    a: 'Tak – gotujemy na miejscu każdego dnia. Nie korzystamy z cateringu. Domowe obiady to część naszej filozofii: dziecko powinno jeść to, co ugotowałaby mama.',
  },
  {
    q: 'Czy przedszkole uczy języka angielskiego?',
    a: 'Tak – ale nie w formie klasycznych "zajęć z angielskiego". W Kolorowym Przedszkolu mamy ciocie, które mówią do dzieci wyłącznie po angielsku przez cały dzień. Dzieci przyswajają język naturalnie, w codziennych sytuacjach – tak jak przyswajają język ojczysty.',
  },
  {
    q: 'Jak wygląda rekrutacja na rok 2026/2027?',
    a: 'Rekrutacja odbywa się przez formularz kontaktowy na stronie lub telefonicznie. Zachęcamy do kontaktu jak najwcześniej – liczba miejsc jest ograniczona, a zainteresowanie duże jest każdego roku.',
  },
  {
    q: 'Jakie zajęcia dodatkowe oferuje przedszkole?',
    a: 'W programie mamy rytmikę, plastykę, ceramikę, dramę i gotowanie z dziećmi. Sala Integracji Sensorycznej (SI) jest dostępna dla wszystkich grup w ramach codziennego programu. Logopeda i psycholog pracują na miejscu — bez konieczności dowożenia dziecka na zewnętrzne wizyty.',
  },
  {
    q: 'Czy w przedszkolu jest psycholog?',
    a: 'Tak. Przy lokalizacji na Zakopiańskiej 8 działa gabinet psychologiczno-logopedyczny. Psycholog jest dostępny dla dzieci wymagających wsparcia oraz dla rodziców — konsultacje po wcześniejszym umówieniu.',
  },
  {
    q: 'Czy jest logopeda na miejscu w przedszkolu?',
    a: 'Tak. Dyplomowany logopeda prowadzi regularne zajęcia z dziećmi w obu lokalizacjach. Wczesna interwencja logopedyczna jest częścią naszego programu — obserwujemy wszystkie dzieci i reagujemy zanim problem się utrwali.',
  },
];
---

<section id="faq" class="bg-brand-warm">
  <div class="max-w-3xl mx-auto px-6 py-16 md:py-24">

    <!-- Eyebrow -->
    <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">
      Pytania i odpowiedzi
    </p>

    <!-- Nagłówek -->
    <h2 class="font-sans italic text-[clamp(2rem,3.5vw,3rem)] text-brand-navy leading-tight mb-4">
      Najczęściej zadawane pytania
    </h2>
    <p class="font-sans text-lg text-brand-navy/70 mb-12">
      Odpowiedzi na pytania, które słyszymy najczęściej od rodziców.
    </p>

    <!-- Lista pytań -->
    <div class="divide-y divide-brand-navy/10">
      {pytania.map((item, i) => (
        <details class="group py-5" open={i === 0}>
          <summary class="flex justify-between items-start cursor-pointer gap-4 list-none">
            <span class="font-sans text-brand-navy font-semibold text-lg leading-snug group-open:text-brand-teal transition-colors duration-200">
              {item.q}
            </span>
            <span class="flex-shrink-0 mt-1 text-brand-teal text-2xl font-light transition-transform duration-200 group-open:rotate-45">
              +
            </span>
          </summary>
          <p class="font-sans mt-4 text-brand-navy/75 leading-relaxed text-base">
            {item.a}
          </p>
        </details>
      ))}
    </div>

  </div>
</section>
