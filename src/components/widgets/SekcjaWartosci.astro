---
import { Image } from 'astro:assets';
import serce from '~/assets/images/wartosci-serce.jpg';
import dom from '~/assets/images/wartosci-dom.jpg';
import wiedza from '~/assets/images/wartosci-wiedza.jpg';
import natura from '~/assets/images/wartosci-natura.jpg';

const slides = [
  { img: serce,  alt: 'Z sercem do dziecka', title: 'Z sercem do dziecka', body: 'Uczymy nazywać i wyrażać emocje, szanując indywidualność każdego malucha. Wspieramy samodzielność i odpowiedzialność poprzez podejmowanie decyzji adekwatnych do wieku. Nasz zespół pedagogów stale się rozwija, by mądrze towarzyszyć dzieciom i rodzicom w zmieniającym się świecie.' },
  { img: dom,    alt: 'Jak w domu',           title: 'Jak w domu',           body: 'Tworzymy kameralne grupy, dopasowane do tempa rozwoju i potrzeb dzieci. Dbamy o przestrzeń na swobodną zabawę i odpoczynek, ceniąc wartość nudy i spontaniczności. Nasze przedszkole działa w sercu Saskiej Kępy, a rodzinne ciepło i bezpieczeństwo budujemy razem z dziećmi i ich bliskimi.' },
  { img: wiedza, alt: 'W świecie wiedzy',     title: 'W świecie wiedzy',     body: 'Inspirujemy się metodami Montessori, Steinera, Korczaka i Pikler. Rozwijamy kreatywność przez sztukę – malowanie, śpiew, taniec i wizyty w teatrze. Języki obce towarzyszą dzieciom codziennie w naturalny sposób, a każde dziecko rozwija się we własnym tempie.' },
  { img: natura, alt: 'W zgodzie z naturą',   title: 'W zgodzie z naturą',   body: 'Dbamy o ogródek warzywny i gotujemy z jego plonów. Jemy zdrowo i lokalnie — wszystkie posiłki przygotowujemy na miejscu. Spędzamy dużo czasu na świeżym powietrzu, niezależnie od pogody, i dbamy o sprawność przez sport, basen i integrację sensoryczną.' },
];
---

<section id="wartosci" class="md:snap-start">

  <!-- Mobile-only heading -->
  <div class="md:hidden bg-brand-cream pt-16 px-6 text-center">
    <h2 class="font-sans italic text-[clamp(1.8rem,8vw,2.5rem)] text-brand-navy mb-6">Nasze wartości</h2>
  </div>

  <!-- Single slider — mobile: card layout, desktop: fullscreen overlay -->
  <div class="relative md:min-h-screen overflow-hidden bg-brand-cream md:bg-transparent px-4 pb-16 md:p-0">

    <!-- Track -->
    <div id="wartosci-track" class="flex transition-transform duration-500 ease-in-out">
      {slides.map((slide) => (
        <div class="min-w-full flex flex-col md:relative md:flex-none md:min-h-screen md:flex md:items-center md:justify-center">

          <!-- Image: card-top on mobile, fullscreen background on desktop -->
          <div class="aspect-[4/3] md:aspect-auto md:absolute md:inset-0 overflow-hidden rounded-t-2xl md:rounded-none">
            <Image
              src={slide.img}
              alt={slide.alt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>

          <!-- Dark overlay — desktop only -->
          <div class="hidden md:block absolute inset-0 bg-black/50" aria-hidden="true"></div>

          <!-- Text content — card bottom on mobile, centered overlay on desktop -->
          <div class="relative z-10
            bg-white border border-t-0 border-brand-navy/10 rounded-b-2xl shadow-sm px-6 pb-7 pt-5
            md:bg-transparent md:border-0 md:rounded-none md:shadow-none md:px-8 md:py-0
            md:text-center md:text-brand-cream md:w-full md:max-w-3xl md:mx-auto">
            <h2 class="
              font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-2
              md:text-brand-cream md:text-[clamp(1.8rem,4vw,3.5rem)] md:leading-tight md:mb-4 md:tracking-widest">
              {slide.title}
            </h2>
            <p class="font-sans text-base leading-relaxed text-brand-navy/75
              md:text-brand-cream/90 md:text-lg md:leading-relaxed">
              {slide.body}
            </p>
          </div>

        </div>
      ))}
    </div>

    <!-- Prev / Next arrows -->
    <button id="wartosci-prev" aria-label="Poprzedni slajd"
      class="absolute left-0 top-[calc(50%-2.5rem)] -translate-y-1/2 z-20
        w-9 h-9 md:w-10 md:h-10 rounded-full flex items-center justify-center transition-all duration-200
        bg-white border border-brand-navy/15 shadow-sm text-brand-navy hover:bg-brand-navy hover:text-brand-cream
        md:left-8 md:bg-brand-cream/15 md:border-0 md:text-brand-cream md:hover:bg-brand-cream/35 md:backdrop-blur-sm
        opacity-60 hover:opacity-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button id="wartosci-next" aria-label="Następny slajd"
      class="absolute right-0 top-[calc(50%-2.5rem)] -translate-y-1/2 z-20
        w-9 h-9 md:w-10 md:h-10 rounded-full flex items-center justify-center transition-all duration-200
        bg-white border border-brand-navy/15 shadow-sm text-brand-navy hover:bg-brand-navy hover:text-brand-cream
        md:right-8 md:bg-brand-cream/15 md:border-0 md:text-brand-cream md:hover:bg-brand-cream/35 md:backdrop-blur-sm
        opacity-60 hover:opacity-100">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-6 md:h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Dots -->
    <div class="flex justify-center gap-3 mt-6 md:absolute md:bottom-8 md:left-1/2 md:-translate-x-1/2 md:mt-0 z-20">
      {slides.map((_, i) => (
        <button
          class="wartosci-dot w-2.5 h-2.5 rounded-full transition-all duration-300
            bg-brand-navy/30 md:bg-brand-cream/40"
          data-index={i}
          aria-label={`Slajd ${i + 1}`}
        />
      ))}
    </div>

  </div>

</section>

<script>
  const track = document.getElementById('wartosci-track') as HTMLElement;
  const dots  = document.querySelectorAll<HTMLElement>('.wartosci-dot');
  const total = 4;
  let current = 0;
  const isMd  = () => window.matchMedia('(min-width: 768px)').matches;

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;

    dots.forEach((dot, i) => {
      const active   = i === current;
      const isDesktop = isMd();
      dot.classList.toggle('bg-brand-cream',     active && isDesktop);
      dot.classList.toggle('bg-brand-cream/40',  !active && isDesktop);
      dot.classList.toggle('bg-brand-navy',       active && !isDesktop);
      dot.classList.toggle('bg-brand-navy/30',    !active && !isDesktop);
      dot.classList.toggle('scale-125', active);
    });
  }

  document.getElementById('wartosci-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('wartosci-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => dot.addEventListener('click', (e) =>
    goTo(Number((e.currentTarget as HTMLElement).dataset.index))
  ));

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;
  track.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  track.addEventListener('touchmove', (e) => {
    const dx = Math.abs(touchStartX - e.touches[0].clientX);
    const dy = Math.abs(touchStartY - e.touches[0].clientY);
    if (dx > dy) e.preventDefault();
  }, { passive: false });
  track.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  });

  goTo(0);
</script>
