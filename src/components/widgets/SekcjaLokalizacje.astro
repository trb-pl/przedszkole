---
import { Image } from 'astro:assets';
import lotarynska from '~/assets/images/lotarynska.jpg';
import zakopianska from '~/assets/images/zakopianska.jpg';

const lokalizacje = [
  {
    img: lotarynska,
    alt: 'Kolorowe Przedszkole — Lotaryńska 18, Warszawa',
    title: 'Lotaryńska 18',
    tagline: 'Prawdziwie domowe przedszkole.',
    body: 'Rodzinny dom Cioci Oli i wujka Tomka, to tu w 1991 roku powstało Kolorowe Przedszkole. Ciepło domowego ogniska sprawia, że najmłodsze dzieci czują się tu bardzo bezpiecznie i komfortowo.',
    href: '/lokalizacje/lotarynska-18',
  },
  {
    img: zakopianska,
    alt: 'Kolorowe Przedszkole — Zakopiańska 8, Warszawa',
    title: 'Zakopiańska 8',
    tagline: 'Zaczarowany ogród.',
    body: 'Willa w sercu Saskiej Kępy z gigantycznym ogrodem to istny raj dla starszej grupy. Do dyspozycji dzieci ponad 1200m² placu zabaw, przestronne i widne sale, sala do zajęć Integracji Sensorycznej (SI), oraz gabinet psychologiczno-logopedyczny.',
    href: '/lokalizacje/zakopianska-8',
  },
];
---

<section id="lokalizacje" class="bg-brand-cream">
  <div class="max-w-6xl mx-auto px-6 py-16 md:py-20 w-full">

    <!-- Section header -->
    <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal text-center mb-3">
      Kolorowe Przedszkole
    </p>
    <h2 class="font-sans italic text-[clamp(1.8rem,3vw,3rem)] text-brand-navy text-center mb-12">
      Nasze lokalizacje
    </h2>

    <!-- Desktop grid (md+) -->
    <div class="hidden md:grid grid-cols-2 gap-8 lg:gap-12">
      {lokalizacje.map((l) => (
        <div class="flex flex-col gap-5">
          <div class="overflow-hidden rounded-2xl aspect-[4/3]">
            <Image src={l.img} alt={l.alt} class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="flex flex-col gap-3">
            <h3 class="font-sans font-bold text-2xl md:text-3xl text-brand-navy">
              {l.title}
            </h3>
            <p class="font-sans italic text-brand-teal text-lg">
              {l.tagline}
            </p>
            <p class="font-sans text-base md:text-lg leading-relaxed text-brand-navy/75">
              {l.body}
            </p>
            <a
              href={l.href}
              class="self-start inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-7 py-3 rounded-lg transition-colors duration-200 hover:bg-brand-coral hover:text-brand-cream mt-1"
            >
              Więcej
            </a>
          </div>
        </div>
      ))}
    </div>

    <!-- Mobile slider (< md): one location at a time -->
    <div class="block md:hidden">
      <div class="relative">

        <div class="overflow-hidden rounded-2xl">
          <div id="lok-track" class="flex transition-transform duration-500 ease-in-out">
            {lokalizacje.map((l) => (
              <div class="min-w-full px-1">
                <div class="flex flex-col gap-5">
                  <div class="overflow-hidden rounded-2xl aspect-[4/3]">
                    <Image src={l.img} alt={l.alt} class="w-full h-full object-cover" loading="lazy" />
                  </div>
                  <div class="flex flex-col gap-3">
                    <h3 class="font-sans font-bold text-2xl text-brand-navy">{l.title}</h3>
                    <p class="font-sans italic text-brand-teal text-lg">{l.tagline}</p>
                    <p class="font-sans text-base leading-relaxed text-brand-navy/75">{l.body}</p>
                    <a
                      href={l.href}
                      class="self-start inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-7 py-3 rounded-lg transition-colors duration-200 hover:bg-brand-coral hover:text-brand-cream mt-1"
                    >
                      Więcej
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <button id="lok-prev" aria-label="Poprzednia lokalizacja"
          class="absolute -left-2 top-32 -translate-y-1/2 z-20
            w-10 h-10 rounded-full flex items-center justify-center
            bg-white border border-brand-navy/10 shadow-md text-brand-navy
            hover:bg-brand-navy hover:text-brand-cream hover:border-brand-navy
            transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <button id="lok-next" aria-label="Następna lokalizacja"
          class="absolute -right-2 top-32 -translate-y-1/2 z-20
            w-10 h-10 rounded-full flex items-center justify-center
            bg-white border border-brand-navy/10 shadow-md text-brand-navy
            hover:bg-brand-navy hover:text-brand-cream hover:border-brand-navy
            transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

      </div>

      <!-- Dots -->
      <div class="flex justify-center gap-3 mt-6">
        {lokalizacje.map((_, i) => (
          <button
            class="lok-dot w-2.5 h-2.5 rounded-full bg-brand-navy/30 transition-all duration-300"
            data-index={i}
            aria-label={`Lokalizacja ${i + 1}`}
          />
        ))}
      </div>
    </div>

  </div>
</section>

<script>
  // Mobile-only slider — desktop grid stays static.
  const track = document.getElementById('lok-track') as HTMLElement | null;
  const dots = document.querySelectorAll<HTMLElement>('.lok-dot');
  const total = 2;
  let current = 0;

  function goTo(index: number) {
    if (!track) return;
    if (index < 0) index = total - 1;
    if (index >= total) index = 0;
    current = index;
    track.style.transform = `translateX(-${current * 100}%)`;

    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-brand-navy/30', i !== current);
      dot.classList.toggle('bg-brand-navy',    i === current);
      dot.classList.toggle('w-6',              i === current);
      dot.classList.toggle('w-2.5',            i !== current);
    });
  }

  document.getElementById('lok-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('lok-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => dot.addEventListener('click', (e) =>
    goTo(Number((e.currentTarget as HTMLElement).dataset.index))
  ));

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;
  track?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  track?.addEventListener('touchmove', (e) => {
    const dx = Math.abs(touchStartX - e.touches[0].clientX);
    const dy = Math.abs(touchStartY - e.touches[0].clientY);
    if (dx > dy) e.preventDefault();
  }, { passive: false });
  track?.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  });

  goTo(0);
</script>
