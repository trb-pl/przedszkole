---
// Reusable hero band for subpages. Designer's colorful "mazy" pattern as the
// band background, with a massive lowercase decorative wordmark in cream
// bleeding past the band edge (knockout / fade effect).
//
// SEO/A11y structure (per audit fix):
// - The real <h1> is sr-only with the full descriptive heading — what
//   Google + screen readers receive.
// - The visible knockout wordmark is a separate <span aria-hidden="true">,
//   purely decorative. Sighted users see only the lowercase short word.
//
// Usage:
//   <HeroMazy
//     title="kuchnia"
//     seoHeading="Kuchnia — domowe obiady gotowane na miejscu"
//   />
import { Image } from 'astro:assets';
import headerMazy from '~/assets/images/header-mazy.png';

interface Props {
  title: string;          // Visible decorative wordmark, e.g. "kuchnia"
  seoHeading?: string;    // Full H1 text for Google/screen readers
}

const { title, seoHeading } = Astro.props;
const heading = seoHeading || title;
---

<div class="relative">
  <Image
    src={headerMazy}
    alt=""
    aria-hidden="true"
    class="w-full h-40 md:h-52 lg:h-60 object-cover"
    loading="eager"
    fetchpriority="high"
    widths={[768, 1280, 1920]}
    sizes="100vw"
  />

  <!-- Real H1 — visually hidden, full SEO-friendly heading. -->
  <h1 class="sr-only">{heading}</h1>

  <!-- Visible knockout-bleed wordmark — decorative only (aria-hidden so
       screen readers don't double-announce the page topic). -->
  <div class="absolute inset-x-0 bottom-0 pointer-events-none" aria-hidden="true">
    <span class="block px-6 text-center font-sans font-black text-[clamp(4.5rem,16vw,12rem)] text-brand-cream leading-[0.85] tracking-tight lowercase translate-y-[13%] md:translate-y-[17%]">
      {title}
    </span>
  </div>
</div>
