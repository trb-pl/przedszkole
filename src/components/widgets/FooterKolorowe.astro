---
import logoUrl from '~/assets/images/logo.svg?url';
---

<footer id="kontakt" class="bg-brand-navy snap-start">
  <div class="max-w-6xl mx-auto px-6 py-16">

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-8">

      <!-- Col 1: Logo + opis -->
      <div class="flex flex-col gap-4">
        <a href="/">
          <img src={logoUrl} alt="Kolorowe Przedszkole" class="h-10 w-auto brightness-0 invert" />
        </a>
        <p class="font-sans text-sm leading-relaxed text-brand-cream/60">
          Rodzinne przedszkole w sercu Saskiej Kępy.<br />
          Budujemy bezpieczny pomost między domem a szkołą od 1991 roku.
        </p>
        <a
          href="https://instagram.com/koloroweprzedszkole"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram Kolorowego Przedszkola"
          class="text-brand-cream/50 hover:text-brand-coral transition-colors duration-200 w-fit"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
          </svg>
        </a>
      </div>

      <!-- Col 2: Nawigacja -->
      <div class="flex flex-col gap-3">
        <h3 class="font-sans font-bold text-xs uppercase tracking-widest text-brand-cream/40 mb-1">
          Menu
        </h3>
        <a href="#olga"        class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">O Nas</a>
        <a href="#lokalizacje" class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">Lokalizacje</a>
        <a href="/blog"        class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">Porady</a>
        <a href="#kontakt"     class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">Kontakt</a>
      </div>

      <!-- Col 3: Kontakt -->
      <div class="flex flex-col gap-3">
        <h3 class="font-sans font-bold text-xs uppercase tracking-widest text-brand-cream/40 mb-1">
          Kontakt
        </h3>
        <p class="font-sans text-sm text-brand-cream/70 leading-relaxed">
          ul. Lotaryńska 18<br />
          03-974 Warszawa
        </p>
        <a href="tel:605657366" class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">
          +48 605 657 366
        </a>
        <a href="mailto:przedszkole@kolorowe.eu" class="font-sans text-sm text-brand-cream/70 hover:text-brand-cream transition-colors duration-200">
          przedszkole@kolorowe.eu
        </a>
        <div class="flex gap-3 mt-2">
          <a href="tel:605657366" class="inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-xs px-5 py-2.5 rounded-lg transition-colors duration-200 hover:bg-brand-cream hover:text-brand-navy">
            Zadzwoń
          </a>
          <a href="mailto:przedszkole@kolorowe.eu" class="inline-block border border-brand-cream/30 text-brand-cream font-sans font-bold uppercase tracking-wider text-xs px-5 py-2.5 rounded-lg transition-colors duration-200 hover:border-brand-cream hover:bg-brand-cream/10">
            Napisz
          </a>
        </div>
      </div>

    </div>

    <!-- Copyright -->
    <div class="border-t border-brand-cream/10 mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="font-sans text-xs text-brand-cream/30">
        © {new Date().getFullYear()} Kolorowe Przedszkole. Wszelkie prawa zastrzeżone.
      </p>
      <p class="font-sans text-xs text-brand-cream/20">
        Saska Kępa, Warszawa · od 1991
      </p>
    </div>

  </div>
</footer>
