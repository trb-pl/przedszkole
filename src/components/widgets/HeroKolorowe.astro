---
import { Image } from 'astro:assets';
import heroImage from '~/assets/images/hero-koloroweprzedszkole.jpg';
---

<section class="relative min-h-screen overflow-hidden">
  <!-- Background image -->
  <Image
    src={heroImage}
    alt="Kolorowe Przedszkole — Saska Kępa, Warszawa od 1991 roku"
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/25"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-screen px-6 gap-8 text-center text-brand-cream">

    <!-- Typography composition -->
    <div class="flex flex-col items-center -gap-4 sm:-gap-6">
      <span class="font-display italic text-[clamp(2.5rem,8vw,8rem)] leading-none text-brand-cream">
        kolorowe
      </span>
      <h1 class="font-sans font-bold uppercase text-[clamp(3rem,14vw,12rem)] leading-none tracking-tight text-brand-cream">
        PRZEDSZKOLE
      </h1>
    </div>

    <!-- Tagline -->
    <p class="font-sans text-xl sm:text-2xl text-brand-cream/95 max-w-2xl mt-8">
      Budujemy bezpieczny pomost między domem a szkołą.
    </p>

    <!-- Sub-tagline -->
    <p class="font-sans text-sm uppercase tracking-[0.3em] text-brand-cream/80">
      od 1991 · Saska Kępa · Warszawa
    </p>

    <!-- CTA -->
    <a
      href="#olga"
      class="inline-block bg-brand-yellow text-brand-navy font-sans font-bold uppercase tracking-wider px-8 py-4 rounded-full transition-colors duration-200 hover:bg-brand-cream hover:text-brand-navy mt-4"
    >
      Poznaj nas
    </a>

  </div>
</section>
