---
import { Image } from 'astro:assets';
import heroImage from '~/assets/images/hero-koloroweprzedszkole.jpg';
import koloroweLogo from '~/assets/images/kolorowe.svg?raw';
import posterImage from '~/assets/images/hero-mobile-poster.jpg';
---

<section id="hero" class="hero relative min-h-screen overflow-hidden">
  <!-- Background wrapper — transformed per-frame for parallax + scale + blur. -->
  <div class="hero-bg absolute inset-0 will-change-transform">
    <Image
      src={heroImage}
      alt="Kolorowe Przedszkole — Saska Kępa, Warszawa od 1991 roku"
      class="absolute inset-0 w-full h-full object-cover hidden md:block"
      loading="eager"
      fetchpriority="high"
    />

    <video
      id="hero-video"
      class="absolute inset-0 w-full h-full object-cover block md:hidden"
      autoplay
      muted
      loop
      playsinline
      poster={posterImage.src}
    >
      <source src="/videos/hero-mobile.mp4" type="video/mp4" />
    </video>
  </div>

  <!-- Overlay — opacity interpolates with scroll progress. -->
  <div class="hero-overlay absolute inset-0 bg-black/25"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-[calc(100vh-4rem)] mt-16 px-6 gap-8 text-center text-brand-cream">

    <!-- Primary block — visible from page-load with staggered fade-in.
         Translates upward slightly with scroll (faster than image = depth). -->
    <div class="hero-primary flex flex-col items-center gap-1 sm:gap-2 will-change-transform">
      <div class="hero-logo w-[65vw] sm:w-[60vw] md:w-[55vw] lg:w-[52vw] max-w-[820px]" set:html={koloroweLogo} />
      <h1 class="hero-title font-sans font-bold uppercase text-[clamp(2rem,12vw,11rem)] leading-none tracking-wider text-brand-cream">
        <span class="sr-only">Kolorowe </span>Przedszkole<span class="sr-only"> na Saskiej Kępie</span>
      </h1>
    </div>

    <!-- Secondary block — reveals on scroll, each line at a different scroll range. -->
    <p class="hero-tagline font-sans text-2xl sm:text-3xl md:text-4xl text-brand-cream/95 max-w-3xl mt-8 will-change-[opacity,transform]">
      między domem a szkołą od 1991 roku
    </p>

    <p class="hero-subtag font-sans text-base sm:text-lg uppercase tracking-[0.3em] text-brand-cream/80 will-change-[opacity,transform]">
      Saska Kępa · Gocław · Warszawa
    </p>

    <a
      href="#olga"
      class="hero-cta inline-block bg-transparent text-brand-cream border-2 border-brand-cream font-sans font-bold uppercase tracking-wider text-sm sm:text-base px-10 py-4 rounded-lg transition-colors duration-300 hover:bg-brand-teal hover:border-brand-teal mt-4 will-change-[opacity,transform]"
    >
      POZNAJ NAS
    </a>

  </div>
</section>

<style>
  /* Initial page-load fade-in for the primary block — preloader feel.
     Opacity only; the JS scroll handler controls all transforms. */
  @keyframes heroFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  .hero-logo {
    opacity: 0;
    animation: heroFadeIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.25s forwards;
  }
  .hero-title {
    opacity: 0;
    animation: heroFadeIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.6s forwards;
  }

  /* Secondary elements start hidden — the JS scroll handler reveals them. */
  .hero-tagline,
  .hero-subtag,
  .hero-cta {
    opacity: 0;
    transform: translate3d(0, 32px, 0);
  }

  /* prefers-reduced-motion: snap everything to final state. */
  @media (prefers-reduced-motion: reduce) {
    .hero-logo,
    .hero-title,
    .hero-tagline,
    .hero-subtag,
    .hero-cta {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>

<script is:inline>
  /* Hero video resume after View Transitions (unchanged). */
  if (!window.__heroVideoInit) {
    window.__heroVideoInit = true;
    var tryPlay = function () {
      var v = document.getElementById('hero-video');
      if (v && v.paused) {
        var p = v.play();
        if (p && typeof p.catch === 'function') p.catch(function () {});
      }
    };
    document.addEventListener('astro:page-load', tryPlay);
    document.addEventListener('astro:after-swap', tryPlay);
  }

  /* Scroll-linked hero animation. Per-frame (rAF) parallax + blur + multi-stage
     fade-in. The whole effect runs over ~first 1× viewport-height of scroll. */
  if (!window.__heroScrollInit) {
    window.__heroScrollInit = true;

    var rafScheduled = false;

    var clamp = function (v, lo, hi) { return v < lo ? lo : v > hi ? hi : v; };
    var lerp  = function (a, b, t) { return a + (b - a) * t; };
    var easeOutCubic = function (t) { return 1 - Math.pow(1 - t, 3); };

    function applyHero() {
      rafScheduled = false;
      var hero = document.getElementById('hero');
      if (!hero) return;

      // Reduced-motion users get the static layout via the CSS @media rule;
      // skip JS-driven transforms entirely.
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var vh = window.innerHeight;
      // Animation completes within 1 viewport-height of scroll from the top.
      var progress = clamp(window.scrollY / vh, 0, 1);

      // Background: parallax up + scale + blur. Scale hides blur edges.
      var bg = hero.querySelector('.hero-bg');
      if (bg) {
        var bgY = -progress * 90;            // parallax: image drifts up ~90px
        var bgScale = 1 + progress * 0.10;   // subtle 10% zoom-in
        var bgBlur = progress * 7;           // 0 → 7px
        bg.style.transform = 'translate3d(0,' + bgY + 'px,0) scale(' + bgScale + ')';
        bg.style.filter = 'blur(' + bgBlur + 'px)';
      }

      // Overlay: 0.25 → 0.55
      var overlay = hero.querySelector('.hero-overlay');
      if (overlay) {
        overlay.style.opacity = lerp(0.25, 0.55, progress);
      }

      // Primary block: small upward drift (faster than image = depth).
      var primary = hero.querySelector('.hero-primary');
      if (primary) {
        primary.style.transform = 'translate3d(0,' + (-progress * 28) + 'px,0)';
      }

      // Staggered reveals for the three secondary elements.
      function revealAt(selector, startP, endP, lift) {
        var el = hero.querySelector(selector);
        if (!el) return;
        var local = (progress - startP) / (endP - startP);
        var t = clamp(local, 0, 1);
        var e = easeOutCubic(t);
        el.style.opacity = e;
        el.style.transform = 'translate3d(0,' + ((1 - e) * lift) + 'px,0)';
      }

      revealAt('.hero-tagline', 0.05, 0.32, 28);
      revealAt('.hero-subtag',  0.22, 0.50, 28);
      revealAt('.hero-cta',     0.40, 0.68, 28);
    }

    function scheduleApply() {
      if (rafScheduled) return;
      rafScheduled = true;
      requestAnimationFrame(applyHero);
    }

    window.addEventListener('scroll', scheduleApply, { passive: true });
    window.addEventListener('resize', scheduleApply, { passive: true });
    document.addEventListener('astro:page-load', scheduleApply);
    applyHero();
  }
</script>
