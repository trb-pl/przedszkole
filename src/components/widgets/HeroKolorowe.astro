---
import { Image } from 'astro:assets';
import heroImage from '~/assets/images/hero-koloroweprzedszkole.jpg';
import koloroweLogo from '~/assets/images/kolorowe.svg?raw';
import posterImage from '~/assets/images/hero-mobile-poster.jpg';
---

<section class="relative min-h-screen overflow-hidden md:snap-start">
  <!-- Background image (desktop) -->
  <Image
    src={heroImage}
    alt="Kolorowe Przedszkole — Saska Kępa, Warszawa od 1991 roku"
    class="absolute inset-0 w-full h-full object-cover hidden md:block"
    loading="eager"
    fetchpriority="high"
  />

  <!-- Background video (mobile) -->
  <video
    class="absolute inset-0 w-full h-full object-cover block md:hidden"
    autoplay
    muted
    loop
    playsinline
    poster={posterImage.src}
  >
    <source src="/videos/hero-mobile.mp4" type="video/mp4" />
  </video>

  <!-- Overlay -->
  <div class="absolute inset-0 bg-black/25"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center h-screen px-6 gap-8 text-center text-brand-cream">

    <!-- Typography composition -->
    <div class="flex flex-col items-center gap-1 sm:gap-2">
      <div class="w-[65vw] sm:w-[60vw] md:w-[55vw] lg:w-[52vw] max-w-[820px]" set:html={koloroweLogo} />
      <h1 class="font-sans font-bold uppercase text-[clamp(2rem,12vw,11rem)] leading-none tracking-wider text-brand-cream">
        PRZEDSZKOLE
      </h1>
    </div>

    <!-- Tagline -->
    <p class="font-sans text-2xl sm:text-3xl md:text-4xl text-brand-cream/95 max-w-3xl mt-8">
      między domem a szkołą od 1991 roku
    </p>

    <!-- Sub-tagline -->
    <p class="font-sans text-base sm:text-lg uppercase tracking-[0.3em] text-brand-cream/80">
      od 1991 · Saska Kępa · Warszawa
    </p>

    <!-- CTA -->
    <a
      href="#olga"
      class="inline-block bg-transparent text-brand-cream border-2 border-brand-cream font-sans font-bold uppercase tracking-wider text-sm sm:text-base px-10 py-4 rounded-lg transition-all duration-300 hover:bg-brand-teal hover:border-brand-teal hover:text-brand-cream mt-4"
    >
      POZNAJ NAS
    </a>

  </div>
</section>
