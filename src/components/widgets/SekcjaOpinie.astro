---
const opinie = [
  {
    tekst: 'Za co kocham przedszkole? Za wszystkich nauczycieli i pracowników, zabawy na powietrzu przy każdej pogodzie, odpowiedni balans pomiędzy zabawą a nauką, za kreatywne prace plastyczne które dziecko każdego dnia przynosi do domu, oraz za wzruszające i wspaniałe uroczystości na Boże Narodzenie, oraz Zakończenie Roku.',
    autor: 'Paulina',
    podpis: 'Mama Zosi',
  },
  {
    tekst: 'Jestem zachwycona poziomem opieki w Kolorowym Przedszkolu. Nauczyciele tworzą ciepłą, bezpieczną przestrzeń, w której dzieci mogą eksplorować świat. Program edukacyjny jest doskonale zbalansowany, łącząc naukę z zabawą. Moja córka codziennie wraca do domu pełna nowych doświadczeń i z uśmiechem na twarzy.',
    autor: 'Gosia',
    podpis: 'Mama Kasi',
  },
  {
    tekst: 'Wybór Kolorowego Przedszkola to najlepsza decyzja, jaką podjęliśmy dla naszego syna. Bogactwo zajęć artystycznych, sportowych i językowych zachwyca nas każdego dnia. Szczególnie cenimy sobie regularną komunikację z wychowawcami oraz czyste, przestronne i inspirujące otoczenie, które sprzyja harmonijnemu rozwojowi dzieci.',
    autor: 'Michał',
    podpis: 'Tata Antka',
  },
  {
    tekst: 'Kolorowe Przedszkole wyróżnia się nowoczesnym podejściem do edukacji wczesnoszkolnej. Doceniam szczególnie małe grupy, które pozwalają na indywidualne traktowanie każdego dziecka. Nauczyciele są wyjątkowo cierpliwi i kreatywni, a różnorodność zajęć dodatkowych sprawia, że dzieci z radością uczestniczą w codziennych aktywnościach.',
    autor: 'Marzena',
    podpis: 'Mama Asi',
  },
];

// Background scattered letters — reproduces the graphic-designer pattern
// reference image: three size tiers (XL/MD/SM), wider rotation range
// (~±55°), all six brand letters with lowercase + capital O.
// Cards have bg-white + z-10 so anything sitting under them is covered.
const XL = 'text-[6rem] md:text-[12rem]';   // big anchor letters
const MD = 'text-5xl md:text-8xl';          // medium accents
const SM = 'text-3xl md:text-5xl';          // small dots/corners

const letters = [
  // Top band — header area
  { c: 'k', top: '2%',  left: '4%',   size: SM, rot: -38 },
  { c: 'r', top: '7%',  left: '12%',  size: SM, rot: 22 },
  { c: 'w', top: '12%', left: '22%',  size: MD, rot: -18 },
  { c: 'O', top: '5%',  left: '48%',  size: XL, rot: -8  },
  { c: 'l', top: '14%', left: '74%',  size: SM, rot: 30 },
  { c: 'r', top: '4%',  left: '85%',  size: SM, rot: 16 },
  { c: 'k', top: '9%',  left: '95%',  size: SM, rot: -26 },

  // Middle-left — outside max-w-7xl on wide screens
  { c: 'e', top: '28%', left: '5%',   size: MD, rot: 24 },
  { c: 'k', top: '46%', left: '3%',   size: XL, rot: -22 },
  { c: 'r', top: '64%', left: '5%',   size: MD, rot: -32 },
  { c: 'w', top: '78%', left: '4%',   size: SM, rot: 28 },

  // Middle-right
  { c: 'l', top: '28%', left: '95%',  size: MD, rot: -20 },
  { c: 'e', top: '46%', left: '96%',  size: MD, rot: 18 },
  { c: 'O', top: '66%', left: '97%',  size: MD, rot: -32 },
  { c: 'k', top: '82%', left: '95%',  size: SM, rot: 40 },

  // Bottom band — below cards
  { c: 'w', top: '88%', left: '6%',   size: MD, rot: -28 },
  { c: 'r', top: '95%', left: '14%',  size: SM, rot: 42 },
  { c: 'o', top: '90%', left: '28%',  size: MD, rot: 18 },
  { c: 'l', top: '94%', left: '44%',  size: SM, rot: -20 },
  { c: 'O', top: '90%', left: '58%',  size: MD, rot: -8 },
  { c: 'r', top: '95%', left: '70%',  size: SM, rot: 30 },
  { c: 'e', top: '88%', left: '82%',  size: MD, rot: -22 },
  { c: 'w', top: '94%', left: '94%',  size: SM, rot: 30 },
];
---

<section id="opinie" class="relative bg-brand-warm py-16 md:py-20 overflow-hidden">

  <!-- Decorative scattered letters — content rendered via CSS ::before
       (.deco-* classes in tailwind.css) so the actual letter character
       doesn't sit in the HTML source as crawler-visible text. -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true" data-nosnippet>
    {letters.map((l) => (
      <span
        class={`absolute text-brand-navy/12 leading-none deco-${l.c} ${l.size}`}
        style={`top: ${l.top}; left: ${l.left}; transform: translate(-50%, -50%) rotate(${l.rot}deg); font-family: 'learning-curve', sans-serif; font-weight: 400;`}
      />
    ))}
  </div>

  <div class="relative max-w-7xl mx-auto px-4 md:px-6">

    <!-- Section heading -->
    <div class="text-center mb-12 md:mb-14">
      <p class="font-sans font-bold uppercase tracking-widest text-xs text-brand-teal mb-3">
        Opinie rodziców
      </p>
      <h2 class="font-sans italic text-[clamp(2rem,4vw,3.2rem)] text-brand-navy leading-tight">
        Co mówią rodzice
      </h2>
    </div>

    <!-- Desktop grid (md+): 2-col on tablet, 4-col on widescreen -->
    <div class="hidden md:grid grid-cols-2 xl:grid-cols-4 gap-5 md:gap-6">
      {opinie.map((opinia) => (
        <article class="group relative flex flex-col gap-5 bg-white rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-6 md:p-7 min-h-[420px] md:min-h-[440px] overflow-hidden">

          <svg xmlns="http://www.w3.org/2000/svg" class="relative w-8 h-8 text-brand-teal/70 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h10zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
          </svg>

          <p class="relative font-sans italic text-base leading-relaxed text-brand-navy/85 flex-1">
            {opinia.tekst}
          </p>

          <div class="relative flex justify-between text-brand-yellow text-xl md:text-2xl tracking-wide pt-1" aria-label="5 z 5 gwiazdek">
            <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
          </div>

          <div class="relative flex flex-col gap-1 pt-4 border-t border-brand-navy/8">
            <p class="font-sans font-bold text-brand-navy text-sm uppercase tracking-wider">{opinia.autor}</p>
            <p class="font-sans italic text-brand-navy/55 text-sm">{opinia.podpis}</p>
          </div>

        </article>
      ))}
    </div>

    <!-- Mobile slider (< md): one card at a time, dots + arrows + swipe -->
    <div class="block md:hidden">
      <div class="relative">

        <div class="overflow-hidden rounded-2xl">
          <div id="opinie-track" class="flex transition-transform duration-500 ease-in-out">
            {opinie.map((opinia) => (
              <div class="min-w-full px-1">
                <article class="relative flex flex-col gap-5 bg-white rounded-2xl shadow-sm p-6 min-h-[420px] overflow-hidden">

                  <svg xmlns="http://www.w3.org/2000/svg" class="relative w-8 h-8 text-brand-teal/70 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h10zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
                  </svg>

                  <p class="relative font-sans italic text-base leading-relaxed text-brand-navy/85 flex-1">
                    {opinia.tekst}
                  </p>

                  <div class="relative flex justify-between text-brand-yellow text-xl tracking-wide pt-1" aria-label="5 z 5 gwiazdek">
                    <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
                  </div>

                  <div class="relative flex flex-col gap-1 pt-4 border-t border-brand-navy/8">
                    <p class="font-sans font-bold text-brand-navy text-sm uppercase tracking-wider">{opinia.autor}</p>
                    <p class="font-sans italic text-brand-navy/55 text-sm">{opinia.podpis}</p>
                  </div>

                </article>
              </div>
            ))}
          </div>
        </div>

        <button id="opinie-prev" aria-label="Poprzednia opinia"
          class="absolute -left-2 top-1/2 -translate-y-1/2 z-20
            w-10 h-10 rounded-full flex items-center justify-center
            bg-white border border-brand-navy/10 shadow-md text-brand-navy
            hover:bg-brand-navy hover:text-brand-cream hover:border-brand-navy
            transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </button>

        <button id="opinie-next" aria-label="Następna opinia"
          class="absolute -right-2 top-1/2 -translate-y-1/2 z-20
            w-10 h-10 rounded-full flex items-center justify-center
            bg-white border border-brand-navy/10 shadow-md text-brand-navy
            hover:bg-brand-navy hover:text-brand-cream hover:border-brand-navy
            transition-all duration-200">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </button>

      </div>

      <!-- Dots -->
      <div class="flex justify-center gap-3 mt-6">
        {opinie.map((_, i) => (
          <button
            class="opinie-dot w-2.5 h-2.5 rounded-full bg-brand-navy/30 transition-all duration-300"
            data-index={i}
            aria-label={`Opinia ${i + 1}`}
          />
        ))}
      </div>
    </div>

    <!-- Link to Google reviews -->
    <div class="text-center mt-12 md:mt-14">
      <a href="https://www.google.com/search?q=Kolorowe+Przedszkole+Saska+Kępa+opinie" target="_blank" rel="noopener noreferrer"
         class="inline-block font-sans text-sm font-semibold uppercase tracking-wider
                text-brand-teal hover:text-brand-coral
                border-b border-current/40 hover:border-current pb-0.5 transition-colors duration-200">
        Zobacz wszystkie opinie w Google →
      </a>
    </div>

  </div>
</section>

<script>
  // Mobile-only slider — desktop renders the grid and these elements stay hidden.
  const track = document.getElementById('opinie-track') as HTMLElement | null;
  const dots = document.querySelectorAll<HTMLElement>('.opinie-dot');
  const total = 4;
  let current = 0;

  function goTo(index: number) {
    if (!track) return;
    if (index < 0) index = total - 1;
    if (index >= total) index = 0;
    current = index;
    track.style.transform = `translateX(-${current * 100}%)`;

    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-brand-navy/30', i !== current);
      dot.classList.toggle('bg-brand-navy',    i === current);
      dot.classList.toggle('w-6',              i === current);
      dot.classList.toggle('w-2.5',            i !== current);
    });
  }

  document.getElementById('opinie-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('opinie-next')?.addEventListener('click', () => goTo(current + 1));
  dots.forEach(dot => dot.addEventListener('click', (e) =>
    goTo(Number((e.currentTarget as HTMLElement).dataset.index))
  ));

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;
  track?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  track?.addEventListener('touchmove', (e) => {
    const dx = Math.abs(touchStartX - e.touches[0].clientX);
    const dy = Math.abs(touchStartY - e.touches[0].clientY);
    if (dx > dy) e.preventDefault();
  }, { passive: false });
  track?.addEventListener('touchend', (e) => {
    const diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 50) goTo(diff > 0 ? current + 1 : current - 1);
  });

  goTo(0);
</script>
