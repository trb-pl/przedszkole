---
import logoUrl from '~/assets/images/logo.svg?url';

const { pathname } = Astro.url;
const isONas      = pathname.startsWith('/o-nas');
const isLokalizacje = pathname.startsWith('/lokalizacje');
const isPorady    = pathname.startsWith('/porady');
const isKontakt   = pathname.startsWith('/kontakt');

const link  = "font-sans text-sm font-semibold text-brand-navy uppercase tracking-wider hover:text-brand-teal transition-colors duration-200";
const active = "font-sans text-sm font-semibold text-brand-teal uppercase tracking-wider";
---

<header
  id="navbar"
  class="fixed top-0 left-0 right-0 z-50 bg-brand-cream/90 backdrop-blur-sm transition-all duration-300"
>
  <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" aria-label="Kolorowe Przedszkole - strona główna">
      <img src={logoUrl} alt="Kolorowe Przedszkole" class="h-9 w-auto" />
    </a>

    <!-- Desktop nav — center -->
    <nav class="hidden md:flex items-center gap-6 absolute left-1/2 -translate-x-1/2" aria-label="Nawigacja główna">

      <!-- O Nas dropdown -->
      <div class="relative group/onas">
        <button
          class={`${isONas ? active : link} flex items-center gap-1 pb-2 -mb-2`}
          aria-haspopup="true" aria-expanded="false"
        >
          O Nas
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 mt-px transition-transform duration-200 group-hover/onas:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <!-- Dropdown panel — pt-2 bridges the gap so hover doesn't break -->
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/onas:opacity-100 group-hover/onas:visible translate-y-1 group-hover/onas:translate-y-0 transition-all duration-200 z-50">
          <div class="w-52 bg-white rounded-xl shadow-lg border border-brand-navy/8 py-2">
            <a href="/o-nas/historia"        class={`block px-4 py-2.5 font-sans text-sm text-brand-navy hover:text-brand-teal hover:bg-brand-warm transition-colors duration-150 ${pathname === '/o-nas/historia' ? 'text-brand-teal' : ''}`}>Historia</a>
            <a href="/o-nas/kadra"           class={`block px-4 py-2.5 font-sans text-sm text-brand-navy hover:text-brand-teal hover:bg-brand-warm transition-colors duration-150 ${pathname === '/o-nas/kadra' ? 'text-brand-teal' : ''}`}>Kadra</a>
            <a href="/o-nas/misja-i-wartosci" class={`block px-4 py-2.5 font-sans text-sm text-brand-navy hover:text-brand-teal hover:bg-brand-warm transition-colors duration-150 ${pathname === '/o-nas/misja-i-wartosci' ? 'text-brand-teal' : ''}`}>Misja i Wartości</a>
          </div>
        </div>
      </div>

      <!-- Lokalizacje dropdown -->
      <div class="relative group/lok">
        <button
          class={`${isLokalizacje ? active : link} flex items-center gap-1 pb-2 -mb-2`}
          aria-haspopup="true" aria-expanded="false"
        >
          Lokalizacje
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 mt-px transition-transform duration-200 group-hover/lok:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        <div class="absolute top-full left-0 pt-2 opacity-0 invisible group-hover/lok:opacity-100 group-hover/lok:visible translate-y-1 group-hover/lok:translate-y-0 transition-all duration-200 z-50">
          <div class="w-52 bg-white rounded-xl shadow-lg border border-brand-navy/8 py-2">
            <a href="/lokalizacje/lotarynska-18"  class={`block px-4 py-2.5 font-sans text-sm text-brand-navy hover:text-brand-teal hover:bg-brand-warm transition-colors duration-150 ${pathname === '/lokalizacje/lotarynska-18' ? 'text-brand-teal' : ''}`}>Lotaryńska 18</a>
            <a href="/lokalizacje/zakopianska-8"  class={`block px-4 py-2.5 font-sans text-sm text-brand-navy hover:text-brand-teal hover:bg-brand-warm transition-colors duration-150 ${pathname === '/lokalizacje/zakopianska-8' ? 'text-brand-teal' : ''}`}>Zakopiańska 8</a>
          </div>
        </div>
      </div>

      <!-- Direct links -->
      <a href="/porady"  class={isPorady  ? active : link}>Porady</a>
      <a href="/kontakt" class={isKontakt ? active : link}>Kontakt</a>

      <!-- Instagram -->
      <a href="https://instagram.com/koloroweprzedszkole" target="_blank" rel="noopener noreferrer" aria-label="Instagram Kolorowego Przedszkola" class="text-brand-navy hover:text-brand-coral transition-colors duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
        </svg>
      </a>

    </nav>

    <!-- REKRUTACJA CTA — prawy koniec -->
    <a
      href="/rekrutacja"
      class="hidden md:inline-block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-xs px-3.5 py-1.5 rounded-md transition-colors duration-200 hover:bg-brand-coral"
    >
      Rekrutacja
    </a>

    <!-- Mobile hamburger -->
    <button id="mobile-menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" aria-label="Otwórz menu" aria-expanded="false">
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300"></span>
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300"></span>
      <span class="block w-6 h-0.5 bg-brand-navy transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-brand-cream border-t border-brand-navy/10 px-6 py-5 flex flex-col gap-1">

    <!-- O Nas accordion -->
    <div>
      <button id="mobile-onas-toggle"
        class="w-full flex items-center justify-between py-3 font-sans text-sm font-semibold text-brand-navy uppercase tracking-wider hover:text-brand-teal transition-colors duration-200"
        aria-expanded="false"
      >
        <span>O Nas</span>
        <svg id="mobile-onas-chevron" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="mobile-onas-menu" class="hidden flex flex-col gap-1 pl-4 pb-2">
        <a href="/o-nas/historia"         class="py-2.5 font-sans text-sm text-brand-navy/75 hover:text-brand-teal transition-colors duration-200">Historia</a>
        <a href="/o-nas/kadra"            class="py-2.5 font-sans text-sm text-brand-navy/75 hover:text-brand-teal transition-colors duration-200">Kadra</a>
        <a href="/o-nas/misja-i-wartosci" class="py-2.5 font-sans text-sm text-brand-navy/75 hover:text-brand-teal transition-colors duration-200">Misja i Wartości</a>
      </div>
    </div>

    <!-- Lokalizacje accordion -->
    <div>
      <button id="mobile-lok-toggle"
        class="w-full flex items-center justify-between py-3 font-sans text-sm font-semibold text-brand-navy uppercase tracking-wider hover:text-brand-teal transition-colors duration-200"
        aria-expanded="false"
      >
        <span>Lokalizacje</span>
        <svg id="mobile-lok-chevron" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
      <div id="mobile-lok-menu" class="hidden flex flex-col gap-1 pl-4 pb-2">
        <a href="/lokalizacje/lotarynska-18" class="py-2.5 font-sans text-sm text-brand-navy/75 hover:text-brand-teal transition-colors duration-200">Lotaryńska 18</a>
        <a href="/lokalizacje/zakopianska-8" class="py-2.5 font-sans text-sm text-brand-navy/75 hover:text-brand-teal transition-colors duration-200">Zakopiańska 8</a>
      </div>
    </div>

    <!-- Direct links -->
    <a href="/porady"  class="py-3 font-sans text-sm font-semibold text-brand-navy uppercase tracking-wider hover:text-brand-teal transition-colors duration-200">Porady</a>
    <a href="/kontakt" class="py-3 font-sans text-sm font-semibold text-brand-navy uppercase tracking-wider hover:text-brand-teal transition-colors duration-200">Kontakt</a>
    <a href="https://instagram.com/koloroweprzedszkole" target="_blank" rel="noopener noreferrer"
      class="py-3 font-sans text-sm font-semibold text-brand-coral uppercase tracking-wider">Instagram ↗</a>

    <!-- REKRUTACJA full-width -->
    <a
      href="/rekrutacja"
      class="mt-2 w-full text-center block bg-brand-teal text-brand-cream font-sans font-bold uppercase tracking-wider text-sm px-8 py-3.5 rounded-lg transition-colors duration-200 hover:bg-brand-coral"
    >
      Rekrutacja
    </a>
  </div>
</header>

<script>
  // Scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar?.classList.add('shadow-md');
      navbar?.classList.remove('bg-brand-cream/90', 'backdrop-blur-sm');
      navbar?.classList.add('bg-brand-cream');
    } else {
      navbar?.classList.remove('shadow-md', 'bg-brand-cream');
      navbar?.classList.add('bg-brand-cream/90', 'backdrop-blur-sm');
    }
  });

  // Smooth scroll to top on logo click
  document.querySelector<HTMLAnchorElement>('header a[href="/"]')?.addEventListener('click', (e) => {
    if (window.location.pathname === '/') {
      e.preventDefault();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  });

  // Mobile menu toggle
  const toggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden');
    mobileMenu?.classList.toggle('hidden', !isOpen);
    toggle.setAttribute('aria-expanded', String(isOpen));
  });

  // Mobile accordion — O Nas
  function setupAccordion(toggleId: string, menuId: string, chevronId: string) {
    const btn = document.getElementById(toggleId);
    const menu = document.getElementById(menuId);
    const chevron = document.getElementById(chevronId);
    btn?.addEventListener('click', () => {
      const open = !menu?.classList.contains('hidden');
      menu?.classList.toggle('hidden', open);
      chevron?.classList.toggle('rotate-180', !open);
      btn.setAttribute('aria-expanded', String(!open));
    });
  }

  setupAccordion('mobile-onas-toggle', 'mobile-onas-menu', 'mobile-onas-chevron');
  setupAccordion('mobile-lok-toggle',  'mobile-lok-menu',  'mobile-lok-chevron');

  // Close mobile menu on any link click (except accordion toggles)
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
